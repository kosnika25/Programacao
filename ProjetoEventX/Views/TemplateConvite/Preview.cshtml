@model ProjetoEventX.Models.TemplateConvitePreviewViewModel

@{
    ViewData["Title"] = "Preview do Template";
}

@section Styles {
<style>
    .preview-page {
        max-width: 1400px;
        margin: 0 auto;
    }

    .preview-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.2rem;
        margin-bottom: 1rem;
        background: #fff;
        border: 1px solid #e9eef5;
        border-radius: 20px;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }

    .preview-header h1 {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 800;
        color: #0f172a;
    }

    .preview-header p {
        margin: .2rem 0 0;
        color: #64748b;
        font-size: .85rem;
    }

    .preview-toolbar {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .preview-btn {
        border: 1px solid #dbe2ea;
        background: #fff;
        color: #0f172a;
        border-radius: 12px;
        padding: .75rem 1rem;
        font-weight: 700;
        font-size: .85rem;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        cursor: pointer;
    }

    .preview-stage {
        background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        border: 1px solid #e9eef5;
        border-radius: 24px;
        min-height: 900px;
        padding: 1.5rem;
        display: flex;
        justify-content: center;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
        overflow: auto;
    }

    .preview-canvas {
        position: relative;
        width: 760px;
        height: 1080px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 24px 50px rgba(15, 23, 42, 0.16);
        overflow: hidden;
        transform-origin: top center;
        transition: transform .2s ease;
    }

    .preview-element {
        position: absolute;
        word-break: break-word;
    }

    .preview-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-weight: 800;
    }
</style>
}

<div class="preview-page">
    <div class="preview-header">
        <div>
            <h1>Preview Final do Convite</h1>
            <p>Template: <strong>@Model.NomeTemplate</strong> · Evento: <strong>@Model.NomeEvento</strong></p>
        </div>

        <div class="preview-toolbar">
            <button class="preview-btn" id="zoomOut"><i class="fas fa-search-minus"></i></button>
            <button class="preview-btn" id="zoomReset">100%</button>
            <button class="preview-btn" id="zoomIn"><i class="fas fa-search-plus"></i></button>
            <button class="preview-btn" onclick="window.print()"><i class="fas fa-print"></i> Imprimir</button>
        </div>
    </div>

    <div class="preview-stage">
        <div class="preview-canvas" id="previewCanvas"></div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const canvas = document.getElementById('previewCanvas');
    let zoom = 1;

    let state = { background: "#ffffff", elements: [] };

    try {
        const loaded = @Html.Raw(Model.LayoutJson);
        if (loaded && typeof loaded === 'object') {
            state = loaded;
        }
    } catch {
        console.warn('Falha ao carregar LayoutJson no preview.');
    }

    function render() {
        canvas.innerHTML = '';
        canvas.style.background = state.background || '#ffffff';

        (state.elements || [])
            .sort((a, b) => a.zIndex - b.zIndex)
            .forEach(item => {
                const el = document.createElement('div');
                el.className = 'preview-element';
                el.style.left = item.x + 'px';
                el.style.top = item.y + 'px';
                el.style.width = item.width + 'px';
                el.style.height = item.height + 'px';
                el.style.zIndex = item.zIndex;
                el.style.color = item.color;
                el.style.background = item.background;
                el.style.fontSize = item.fontSize + 'px';
                el.style.fontFamily = item.fontFamily;
                el.style.fontWeight = item.fontWeight || '600';

                if (item.type === 'button') {
                    el.classList.add('preview-button');
                    el.textContent = item.text || '';
                } else if (item.type === 'image') {
                    el.innerHTML = '<div style="width:100%;height:100%;display:grid;place-items:center;background:#f1f5f9;color:#64748b;border:1px dashed #cbd5e1;border-radius:12px;">Imagem</div>';
                } else {
                    el.textContent = item.text || '';
                }

                canvas.appendChild(el);
            });
    }

    function applyZoom() {
        canvas.style.transform = `scale(${zoom})`;
    }

    document.getElementById('zoomIn').addEventListener('click', () => {
        zoom = Math.min(1.6, zoom + 0.1);
        applyZoom();
    });

    document.getElementById('zoomOut').addEventListener('click', () => {
        zoom = Math.max(0.5, zoom - 0.1);
        applyZoom();
    });

    document.getElementById('zoomReset').addEventListener('click', () => {
        zoom = 1;
        applyZoom();
    });

    render();
})();
</script>
}