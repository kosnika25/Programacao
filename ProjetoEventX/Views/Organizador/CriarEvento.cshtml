@model ProjetoEventX.Models.Evento
@{
    ViewData["Title"] = "Criar Evento";
    var googleMapsApiKey = ViewBag.GoogleMapsApiKey as string ?? "";
}

<div class="container py-5 animate-in">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg rounded-4 border-0">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-2 text-primary"><i class="fas fa-calendar-plus me-2"></i> Novo Evento</h2>
                    <div class="text-muted mb-4">Preencha os dados para criar um novo evento. Os campos estão agrupados para facilitar o preenchimento.</div>
                    <form asp-action="CriarEvento" method="post" id="formCriarEvento">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                        <!-- Dados principais -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Dados principais</h5>
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label asp-for="NomeEvento" class="form-label">Nome do evento</label>
                                    <input asp-for="NomeEvento" class="form-control form-control-lg rounded-pill" placeholder="Evento de Exemplo" />
                                    <span asp-validation-for="NomeEvento" class="invalid-feedback d-block"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="TipoEvento" class="form-label">Tipo de evento</label>
                                    <input asp-for="TipoEvento" class="form-control rounded-pill" placeholder="Casamento, Aniversário, etc." />
                                    <span asp-validation-for="TipoEvento" class="invalid-feedback d-block"></span>
                                </div>
                            </div>
                        </div>
                        <!-- Data e horário -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Data e horário</h5>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="DataEvento" class="form-label">Data</label>
                                    <input asp-for="DataEvento" type="date" class="form-control rounded-pill" />
                                    <span asp-validation-for="DataEvento" class="invalid-feedback d-block"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="HoraInicio" class="form-label">Hora de início</label>
                                    <input asp-for="HoraInicio" type="time" class="form-control rounded-pill" />
                                    <span asp-validation-for="HoraInicio" class="invalid-feedback d-block"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="HoraFim" class="form-label">Hora de fim</label>
                                    <input asp-for="HoraFim" type="time" class="form-control rounded-pill" />
                                    <span asp-validation-for="HoraFim" class="invalid-feedback d-block"></span>
                                </div>
                            </div>
                        </div>
                        <!-- Local -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Local</h5>
                            <label class="form-label"><i class="fas fa-map-marker-alt text-danger me-1"></i> Local do evento</label>
                            <div class="position-relative mb-2">
                                <input type="text" id="localBusca" class="form-control rounded-pill" placeholder="Busque o endereço do evento..." autocomplete="off" />
                                <i class="fas fa-search position-absolute" style="right: 16px; top: 50%; transform: translateY(-50%); color: #999;"></i>
                            </div>
                            <input type="hidden" name="LocalNome" id="localNome" />
                            <input type="hidden" name="LocalEndereco" id="localEndereco" />
                            <div id="localSelecionado" class="bg-light rounded-3 p-3 mb-2 d-none">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <strong id="localNomeDisplay" class="text-danger"></strong>
                                        <p id="localEnderecoDisplay" class="mb-0 text-muted small"></p>
                                    </div>
                                    <button type="button" id="btnRemoverLocal" class="btn btn-sm btn-outline-secondary"><i class="fas fa-times-circle"></i></button>
                                </div>
                            </div>
                            <div id="mapContainer" class="mb-2 d-none rounded-3 overflow-hidden border border-secondary-subtle">
                                <div id="map" style="width: 100%; height: 220px;"></div>
                            </div>
                        </div>
                        <!-- Descrição -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Descrição</h5>
                            <label asp-for="DescricaoEvento" class="form-label">Descrição do evento</label>
                            <textarea asp-for="DescricaoEvento" class="form-control rounded-3" rows="4" placeholder="Um evento especial para lembrar..."></textarea>
                            <span asp-validation-for="DescricaoEvento" class="invalid-feedback d-block"></span>
                        </div>
                        <!-- Capa/Imagem -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Capa/Imagem</h5>
                            <label class="form-label">Imagem de capa (opcional)</label>
                            <input type="file" name="ImagemCapa" class="form-control rounded-pill" accept="image/*" />
                        </div>
                        <!-- Público e custo -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Público e custo</h5>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="PublicoEstimado" class="form-label">Público estimado</label>
                                    <input asp-for="PublicoEstimado" type="number" class="form-control rounded-pill" min="1" />
                                    <span asp-validation-for="PublicoEstimado" class="invalid-feedback d-block"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Custo estimado (R$)</label>
                                    <div class="position-relative">
                                        <span class="position-absolute" style="left: 16px; top: 50%; transform: translateY(-50%); color: #666; font-weight: 600;">R$</span>
                                        <input type="text" name="CustoEstimadoTexto" id="custoEstimadoTexto" class="form-control rounded-pill" inputmode="decimal" placeholder="0,00" style="padding-left: 40px;" value="@(Model?.CustoEstimado > 0 ? Model.CustoEstimado.ToString("N2", new System.Globalization.CultureInfo("pt-BR")) : "")" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Botões -->
                        <div class="d-flex gap-3 mt-4 justify-content-end">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">Salvar Evento</button>
                            <a asp-action="Dashboard" class="btn btn-outline-secondary btn-lg rounded-pill px-5 fw-bold">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    @if (!string.IsNullOrEmpty(googleMapsApiKey) && googleMapsApiKey != "USE_ENV_VARIABLE")
    {
        <script src="https://maps.googleapis.com/maps/api/js?key=@googleMapsApiKey&libraries=places&callback=initGoogleMaps" async defer></script>
    }

    <script>
        // ===== Máscara de valor para Custo Estimado =====
        (function() {
            var custoInput = document.getElementById('custoEstimadoTexto');
            if (custoInput) {
                custoInput.addEventListener('input', function(e) {
                    var val = this.value.replace(/[^0-9,\.]/g, '');
                    // Permitir apenas um separador decimal
                    var parts = val.split(/[,\.]/);
                    if (parts.length > 2) {
                        val = parts[0] + ',' + parts.slice(1).join('');
                    }
                    this.value = val;
                });
            }

            // Converter vírgula → ponto antes do submit
            var form = document.getElementById('formCriarEvento');
            if (form) {
                form.addEventListener('submit', function() {
                    if (custoInput && custoInput.value) {
                        custoInput.value = custoInput.value.replace(',', '.');
                    }
                });
            }
        })();

        // ===== Google Maps Places Autocomplete =====
        var map, marker, autocomplete;

        function initGoogleMaps() {
            // Inicializar mapa (centrado no Brasil)
            map = new google.maps.Map(document.getElementById('map'), {
                center: { lat: -15.7801, lng: -47.9292 },
                zoom: 4,
                mapTypeControl: false,
                streetViewControl: false,
                fullscreenControl: false
            });

            marker = new google.maps.Marker({
                map: map,
                draggable: false
            });

            // Configurar Autocomplete
            var input = document.getElementById('localBusca');
            autocomplete = new google.maps.places.Autocomplete(input, {
                types: ['establishment', 'geocode'],
                componentRestrictions: { country: 'br' }
            });

            autocomplete.addListener('place_changed', function() {
                var place = autocomplete.getPlace();
                if (!place.geometry) return;

                // Preencher dados
                document.getElementById('localNome').value = place.name || '';
                document.getElementById('localEndereco').value = place.formatted_address || '';
                document.getElementById('localNomeDisplay').textContent = place.name || 'Local selecionado';
                document.getElementById('localEnderecoDisplay').textContent = place.formatted_address || '';

                // Mostrar info e mapa
                document.getElementById('localSelecionado').style.display = 'block';
                document.getElementById('mapContainer').style.display = 'block';

                // Centralizar mapa
                map.setCenter(place.geometry.location);
                map.setZoom(16);
                marker.setPosition(place.geometry.location);
                marker.setVisible(true);
            });
        }

        // Remover local selecionado
        document.getElementById('btnRemoverLocal').addEventListener('click', function() {
            document.getElementById('localNome').value = '';
            document.getElementById('localEndereco').value = '';
            document.getElementById('localBusca').value = '';
            document.getElementById('localSelecionado').style.display = 'none';
            document.getElementById('mapContainer').style.display = 'none';
            if (marker) marker.setVisible(false);
        });

        // Se não tem Google Maps API, usar busca manual
        @if (string.IsNullOrEmpty(googleMapsApiKey) || googleMapsApiKey == "USE_ENV_VARIABLE")
        {
            <text>
            (function() {
                var input = document.getElementById('localBusca');
                input.placeholder = 'Digite o endereço do evento...';
                
                input.addEventListener('change', function() {
                    if (this.value.trim()) {
                        document.getElementById('localNome').value = this.value.trim();
                        document.getElementById('localEndereco').value = this.value.trim();
                        document.getElementById('localNomeDisplay').textContent = this.value.trim();
                        document.getElementById('localEnderecoDisplay').textContent = this.value.trim();
                        document.getElementById('localSelecionado').style.display = 'block';
                        
                        // Mostrar mapa estático via embed (sem API key necessário)
                        var mapDiv = document.getElementById('map');
                        var query = encodeURIComponent(this.value.trim());
                        mapDiv.innerHTML = '<iframe width="100%" height="250" frameborder="0" style="border:0" ' +
                            'src="https://www.google.com/maps?q=' + query + '&output=embed" allowfullscreen></iframe>';
                        document.getElementById('mapContainer').style.display = 'block';
                    }
                });
            })();
            </text>
        }
    </script>
}



