@model ProjetoEventX.Models.OrganizadorDashboardViewModel

@{
    ViewBag.Title = "Dashboard do Organizador";
}

@if (Model == null)
{
    <div class="alert alert-danger">Erro ao carregar dashboard.</div>
    return;
}

<div class="d-flex min-vh-100">

    <!-- SIDEBAR -->
    <nav class="bg-dark text-white p-4" style="width:240px;">
        <h3>EventX</h3>

        <ul class="nav flex-column">
            <li><a class="nav-link text-white" asp-action="Dashboard">Dashboard</a></li>
            <li><a class="nav-link text-white" asp-action="MeusEventos">Eventos</a></li>
            <li><a class="nav-link text-white" asp-action="Orcamento">Financeiro</a></li>
            <li><a class="nav-link text-white" asp-action="Profile">Perfil</a></li>
        </ul>
    </nav>

    <!-- CONTENT -->
    <div class="flex-grow-1 p-4 bg-light">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Olá, @(Model.Pessoa?.Nome ?? Model.UserName)</h2>

            <img src="@(string.IsNullOrEmpty(Model.FotoPerfilUrl) ? "/img/user.png" : Model.FotoPerfilUrl)"
                 style="width:40px;height:40px;border-radius:50%;" />
        </div>

        <!-- MÉTRICAS -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h6>Eventos</h6>
                    <h3>@(ViewBag.TotalEventos ?? 0)</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h6>Convidados</h6>
                    <h3>@(ViewBag.TotalConvidados ?? 0)</h3>
                    <small>@(ViewBag.ConvidadosConfirmados ?? 0) confirmados</small>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h6>Despesas</h6>
                    <h3>R$ @((ViewBag.TotalDespesas ?? 0m).ToString("N2"))</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h6>Concluídos</h6>
                    <h3>@(ViewBag.EventosConcluidos ?? 0)</h3>
                </div>
            </div>
        </div>

        <!-- PRÓXIMO EVENTO -->
        @if (Model.ProximoEvento != null)
        {
            <div class="card mb-4 p-3">
                <h5>Próximo Evento</h5>

                <strong>@Model.ProximoEvento.NomeEvento</strong><br />

                <span>
                    @Model.ProximoEvento.DataEvento.ToString("dd/MM/yyyy")
                </span><br />

                <span>@Model.ProximoEvento.TipoEvento</span>
            </div>
        }

        <!-- LISTA DE EVENTOS -->
        <div class="card p-3 mb-4">
            <h5>Meus Eventos</h5>

            @if (Model.Eventos != null && Model.Eventos.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Data</th>
                            <th>Tipo</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var evento in Model.Eventos)
                        {
                            <tr>
                                <td>@evento.NomeEvento</td>
                                <td>@evento.DataEvento.ToString("dd/MM/yyyy")</td>
                                <td>@evento.TipoEvento</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>Nenhum evento encontrado.</p>
            }
        </div>

        <!-- RESUMO FINANCEIRO -->
        @{
            var totalOrc = (decimal?)(ViewBag.TotalOrcamento) ?? 0m;
            var totalGasto = (decimal?)(ViewBag.TotalDespesas) ?? 0m;
            var saldo = totalOrc - totalGasto;
        }

        <div class="card p-3 mb-4">
            <h5>Resumo Financeiro</h5>

            <p><strong>Orçamento:</strong> R$ @totalOrc.ToString("N2")</p>
            <p><strong>Gasto:</strong> R$ @totalGasto.ToString("N2")</p>
            <p><strong>Saldo:</strong> R$ @saldo.ToString("N2")</p>
        </div>

        <!-- PERFIL -->
        <div class="card p-3">
            <h5>Perfil</h5>

            <p><strong>Nome:</strong> @(Model.Pessoa?.Nome ?? "-")</p>
            <p><strong>Email:</strong> @(Model.Email ?? "-")</p>
            <p><strong>Telefone:</strong> @(Model.Pessoa?.Telefone ?? "-")</p>
            <p><strong>Cidade:</strong> @(Model.Pessoa?.Cidade ?? "-")</p>
        </div>

    </div>
</div>