@model ProjetoEventX.Models.Organizador
@{
    ViewData["Title"] = "Dashboard - Organizador";
    Layout = "_Layout";
    var proximoEvento = ViewBag.ProximoEvento as ProjetoEventX.Models.Evento;
    var notificacoes = ViewBag.Notificacoes as List<ProjetoEventX.Models.Notificacao> ?? new List<ProjetoEventX.Models.Notificacao>();
}

<!-- Welcome Banner -->
<div class="welcome-banner animate-in">
    <div class="d-flex align-items-center">
        <div class="me-3" style="width: 52px; height: 52px; background: rgba(255,255,255,0.15); border-radius: 14px; display:flex; align-items:center; justify-content:center; font-size:1.5rem;">
            <i class="fas fa-hand-wave" style="color: #FDE68A;"></i>
        </div>
        <div>
            <h2>Olá, @(Model.Pessoa?.Nome ?? Model.UserName)!</h2>
            <p>Gerencie seus eventos com praticidade e eficiência</p>
        </div>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="stat-card purple">
            <div class="stat-icon purple"><i class="fas fa-calendar-alt"></i></div>
            <div class="stat-info">
                <div class="stat-label">Eventos</div>
                <div class="stat-value">@ViewBag.TotalEventos</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card green">
            <div class="stat-icon green"><i class="fas fa-users"></i></div>
            <div class="stat-info">
                <div class="stat-label">Convidados</div>
                <div class="stat-value">@ViewBag.TotalConvidados</div>
                <div class="stat-change up"><i class="fas fa-check-circle"></i> @ViewBag.ConvidadosConfirmados confirmados</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card orange">
            <div class="stat-icon orange"><i class="fas fa-wallet"></i></div>
            <div class="stat-info">
                <div class="stat-label">Despesas</div>
                <div class="stat-value">R$ @(((decimal)ViewBag.TotalDespesas).ToString("N0"))</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card blue">
            <div class="stat-icon blue"><i class="fas fa-check-circle"></i></div>
            <div class="stat-info">
                <div class="stat-label">Concluídos</div>
                <div class="stat-value">@ViewBag.EventosConcluidos</div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row 1 -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="chart-card">
            <div class="chart-card-title"><i class="fas fa-chart-bar me-2" style="color: var(--ex-primary);"></i>Gastos por Evento</div>
            <div style="height: 280px; position: relative;">
                <canvas id="gastosEventoChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card">
            <div class="chart-card-title"><i class="fas fa-user-check me-2" style="color: var(--ex-success);"></i>Status dos Convidados</div>
            <div class="d-flex justify-content-center" style="height: 280px; position: relative;">
                <canvas id="convidadosChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row 2 -->
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="chart-card">
            <div class="chart-card-title"><i class="fas fa-chart-line me-2" style="color: var(--ex-warning);"></i>Despesas Mensais</div>
            <div style="height: 240px; position: relative;">
                <canvas id="despesasMensaisChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-3">
        <div class="chart-card text-center">
            <div class="chart-card-title"><i class="fas fa-tasks me-2" style="color: var(--ex-info);"></i>Tarefas</div>
            @{
                var totalTarefas = (int)ViewBag.TotalTarefas;
                var tarefasConcluidas = (int)ViewBag.TarefasConcluidas;
                var percentTarefas = totalTarefas > 0 ? (int)Math.Round((double)tarefasConcluidas / totalTarefas * 100) : 0;
            }
            <div class="d-flex justify-content-center my-3">
                <div style="position: relative; display: inline-flex; align-items: center; justify-content: center;">
                    <canvas id="tarefasRing" width="140" height="140"></canvas>
                    <span style="position: absolute; font-size: 1.4rem; font-weight: 800; color: var(--ex-text);">@percentTarefas%</span>
                </div>
            </div>
            <div style="font-size: 0.82rem; color: var(--ex-text-secondary);">
                <strong>@tarefasConcluidas</strong> de <strong>@totalTarefas</strong> concluídas
            </div>
        </div>
    </div>
    <div class="col-lg-3">
        <div class="chart-card text-center">
            <div class="chart-card-title"><i class="fas fa-shopping-cart me-2" style="color: var(--ex-primary-light);"></i>Pedidos</div>
            <div class="d-flex justify-content-center" style="height: 180px; position: relative;">
                <canvas id="pedidosChart"></canvas>
            </div>
            <div style="font-size: 0.82rem; color: var(--ex-text-secondary); margin-top: 0.5rem;">
                <strong>@ViewBag.TotalPedidos</strong> pedidos no total
            </div>
        </div>
    </div>
</div>

<!-- Financial Summary -->
@{
    var totalOrc = (decimal)ViewBag.TotalOrcamento;
    var totalGasto = (decimal)ViewBag.TotalDespesas;
    var saldo = totalOrc - totalGasto;
    var percentOrc = totalOrc > 0 ? (double)(totalGasto / totalOrc) * 100 : 0;
    var barColor = percentOrc > 100 ? "var(--ex-danger)" : percentOrc > 80 ? "var(--ex-warning)" : "var(--ex-success)";
}
<div class="saas-card mb-4">
    <div class="saas-card-header">
        <h5 class="saas-card-title"><i class="fas fa-coins me-2" style="color: var(--ex-warning);"></i>Resumo Financeiro</h5>
        <a asp-action="Orcamento" class="btn btn-saas-outline btn-sm">Ver detalhes <i class="fas fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row align-items-center">
        <div class="col-md-4">
            <div class="d-flex justify-content-between mb-2" style="font-size: 0.85rem;">
                <span style="color: var(--ex-text-secondary);">Orçamento Estimado</span>
                <strong>R$ @totalOrc.ToString("N2")</strong>
            </div>
            <div class="d-flex justify-content-between mb-2" style="font-size: 0.85rem;">
                <span style="color: var(--ex-text-secondary);">Total Gasto</span>
                <strong style="color: var(--ex-danger);">R$ @totalGasto.ToString("N2")</strong>
            </div>
            <div class="d-flex justify-content-between" style="font-size: 0.85rem;">
                <span style="color: var(--ex-text-secondary);">Saldo</span>
                <strong style="color: @(saldo >= 0 ? "var(--ex-success)" : "var(--ex-danger)");">R$ @saldo.ToString("N2")</strong>
            </div>
        </div>
        <div class="col-md-8">
            <div class="d-flex justify-content-between mb-1" style="font-size: 0.78rem; color: var(--ex-text-muted);">
                <span>@percentOrc.ToString("N0")% utilizado</span>
                <span>R$ @totalGasto.ToString("N2") / R$ @totalOrc.ToString("N2")</span>
            </div>
            <div class="progress-saas">
                <div class="progress-bar" style="width: @Math.Min(percentOrc, 100).ToString("N0")%; background: @barColor !important;"></div>
            </div>
        </div>
    </div>
</div>

<!-- Main Content Row -->
<div class="row g-4">
    <!-- Left Column -->
    <div class="col-lg-8">
        @if (proximoEvento != null)
        {
            <div class="saas-card mb-4" style="border-left: 4px solid var(--ex-primary);">
                <div class="d-flex align-items-center mb-2">
                    <i class="fas fa-star me-2" style="color: var(--ex-warning);"></i>
                    <h6 style="font-weight: 700; margin: 0; color: var(--ex-primary);">Próximo Evento</h6>
                </div>
                <div style="font-size: 1.2rem; font-weight: 700; margin: 0.5rem 0; color: var(--ex-text);">@proximoEvento.NomeEvento</div>
                <div class="d-flex flex-wrap gap-3" style="font-size: 0.85rem; color: var(--ex-text-secondary);">
                    <span><i class="fas fa-calendar me-1" style="color: var(--ex-primary-light);"></i> @proximoEvento.DataEvento.ToString("dd/MM/yyyy")</span>
                    <span><i class="fas fa-clock me-1" style="color: var(--ex-primary-light);"></i> @proximoEvento.HoraInicio - @proximoEvento.HoraFim</span>
                    <span><i class="fas fa-tag me-1" style="color: var(--ex-primary-light);"></i> @proximoEvento.TipoEvento</span>
                    <span><i class="fas fa-users me-1" style="color: var(--ex-primary-light);"></i> @proximoEvento.PublicoEstimado pessoas</span>
                </div>
            </div>
        }

        <!-- Events List -->
        <div class="saas-card">
            <div class="saas-card-header">
                <h5 class="saas-card-title"><i class="fas fa-list me-2"></i>Meus Eventos</h5>
                <a asp-action="CriarEvento" class="btn btn-saas-primary btn-sm"><i class="fas fa-plus me-1"></i>Novo</a>
            </div>
            @if (Model.Eventos != null && Model.Eventos.Any())
            {
                @foreach (var evento in Model.Eventos.OrderByDescending(e => e.DataEvento).Take(5))
                {
                    <a asp-action="DetalhesEvento" asp-route-id="@evento.Id" style="text-decoration: none; color: inherit;">
                        <div style="display: flex; align-items: center; padding: 0.85rem; border-radius: var(--radius-md); background: var(--ex-bg); margin-bottom: 0.6rem; transition: all 0.2s;">
                            <div style="min-width: 50px; text-align: center; margin-right: 1rem;">
                                <div style="font-size: 1.4rem; font-weight: 800; color: var(--ex-primary); line-height: 1;">@evento.DataEvento.Day</div>
                                <div style="font-size: 0.7rem; color: var(--ex-text-muted); text-transform: uppercase; font-weight: 600;">@evento.DataEvento.ToString("MMM")</div>
                            </div>
                            <div style="flex: 1;">
                                <div style="font-weight: 600; font-size: 0.92rem; color: var(--ex-text);">@evento.NomeEvento</div>
                                <div style="font-size: 0.78rem; color: var(--ex-text-muted);">@evento.TipoEvento · @evento.HoraInicio - @evento.HoraFim</div>
                            </div>
                            @{
                                var statusClass = evento.StatusEvento?.ToLower() switch {
                                    "planejado" => "badge-warning",
                                    "em andamento" => "badge-info",
                                    "concluído" or "finalizado" => "badge-success",
                                    "cancelado" => "badge-danger",
                                    _ => "badge-warning"
                                };
                            }
                            <span class="badge-saas @statusClass">@evento.StatusEvento</span>
                        </div>
                    </a>
                }
                @if (Model.Eventos.Count > 5)
                {
                    <div class="text-center mt-3">
                        <a asp-action="MeusEventos" class="btn btn-saas-outline btn-sm">Ver todos os eventos</a>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-calendar-plus d-block"></i>
                    <h5>Nenhum evento criado</h5>
                    <p>Comece criando seu primeiro evento.</p>
                    <a asp-action="CriarEvento" class="btn btn-saas-primary btn-sm"><i class="fas fa-plus me-1"></i>Criar Evento</a>
                </div>
            }
        </div>
    </div>

    <!-- Right Column -->
    <div class="col-lg-4">
        <!-- Notifications -->
        <div class="saas-card mb-4">
            <div class="saas-card-header">
                <h5 class="saas-card-title">
                    <i class="fas fa-bell me-2" style="color: var(--ex-warning);"></i>Notificações
                    @if ((int)ViewBag.NotificacoesNaoLidas > 0)
                    {
                        <span class="badge rounded-pill ms-1" style="background: var(--ex-danger); font-size: 0.68rem; color: #fff;">@ViewBag.NotificacoesNaoLidas</span>
                    }
                </h5>
            </div>
            @if (notificacoes.Any())
            {
                @foreach (var notif in notificacoes)
                {
                    var iconBg = notif.Tipo?.ToLower() switch {
                        "presenca" or "confirmacao" => "var(--ex-success)",
                        "lembrete" => "var(--ex-warning)",
                        "mudanca" or "alteracao" => "var(--ex-info)",
                        _ => "var(--ex-text-muted)"
                    };
                    var iconFa = notif.Tipo?.ToLower() switch {
                        "presenca" or "confirmacao" => "fa-user-check",
                        "lembrete" => "fa-clock",
                        "mudanca" or "alteracao" => "fa-edit",
                        _ => "fa-bell"
                    };
                    <div style="display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.7rem; border-radius: var(--radius-sm); margin-bottom: 0.35rem; @(!notif.Lida ? "background: var(--ex-warning-bg);" : "")">
                        <div style="width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; color: #fff; flex-shrink: 0; background: @iconBg;">
                            <i class="fas @iconFa"></i>
                        </div>
                        <div>
                            <div style="font-size: 0.82rem; color: var(--ex-text); line-height: 1.35;">@notif.MensagemNotificacao</div>
                            <div style="font-size: 0.7rem; color: var(--ex-text-muted); margin-top: 2px;">@notif.DataEnvio.ToString("dd/MM HH:mm")</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-3" style="color: var(--ex-text-muted); font-size: 0.85rem;">
                    <i class="fas fa-bell-slash d-block mb-2" style="font-size: 1.8rem; opacity: 0.3;"></i>
                    Nenhuma notificação
                </div>
            }
        </div>

        <!-- Quick Actions -->
        <div class="saas-card mb-4">
            <div class="saas-card-header">
                <h5 class="saas-card-title"><i class="fas fa-bolt me-2" style="color: var(--ex-warning);"></i>Ações Rápidas</h5>
            </div>
            <div class="row g-2">
                <div class="col-6">
                    <a asp-action="CriarEvento" class="quick-action"><i class="fas fa-calendar-plus"></i><span>Criar Evento</span></a>
                </div>
                <div class="col-6">
                    <a asp-controller="Marketplace" asp-action="Index" class="quick-action"><i class="fas fa-store"></i><span>Marketplace</span></a>
                </div>
                <div class="col-6">
                    <a asp-controller="Organizador" asp-action="Orcamento" class="quick-action"><i class="fas fa-wallet"></i><span>Financeiro</span></a>
                </div>
                <div class="col-6">
                    <a asp-controller="IA" asp-action="Index" class="quick-action"><i class="fas fa-robot"></i><span>Assistente IA</span></a>
                </div>
                <div class="col-6">
                    <a asp-controller="TemplateConvite" asp-action="Index" class="quick-action"><i class="fas fa-palette"></i><span>Convites</span></a>
                </div>
                <div class="col-6">
                    <a asp-controller="RankingFornecedor" asp-action="Index" class="quick-action"><i class="fas fa-ranking-star"></i><span>Ranking</span></a>
                </div>
            </div>
        </div>

        <!-- Profile Info -->
        <div class="saas-card">
            <div class="saas-card-header">
                <h5 class="saas-card-title"><i class="fas fa-user-circle me-2"></i>Meu Perfil</h5>
            </div>
            <div class="d-flex flex-column gap-2" style="font-size: 0.85rem;">
                <div class="d-flex align-items-center">
                    <i class="fas fa-user me-2" style="width: 18px; color: var(--ex-text-muted);"></i>
                    <span style="color: var(--ex-text-secondary); min-width: 70px;">Nome</span>
                    <strong class="ms-auto">@(Model.Pessoa?.Nome ?? "—")</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i class="fas fa-envelope me-2" style="width: 18px; color: var(--ex-text-muted);"></i>
                    <span style="color: var(--ex-text-secondary); min-width: 70px;">Email</span>
                    <strong class="ms-auto" style="font-size: 0.8rem;">@(Model.Email ?? "—")</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i class="fas fa-phone me-2" style="width: 18px; color: var(--ex-text-muted);"></i>
                    <span style="color: var(--ex-text-secondary); min-width: 70px;">Telefone</span>
                    <strong class="ms-auto">@(Model.Pessoa?.Telefone ?? "—")</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i class="fas fa-map-marker-alt me-2" style="width: 18px; color: var(--ex-text-muted);"></i>
                    <span style="color: var(--ex-text-secondary); min-width: 70px;">Cidade</span>
                    <strong class="ms-auto">@(Model.Pessoa?.Cidade ?? "—")/@(Model.Pessoa?.UF ?? "—")</strong>
                </div>
                <div class="d-flex align-items-center">
                    <i class="fas fa-calendar-check me-2" style="width: 18px; color: var(--ex-text-muted);"></i>
                    <span style="color: var(--ex-text-secondary); min-width: 70px;">Desde</span>
                    <strong class="ms-auto">@Model.DataCadastro.ToString("MMM/yyyy")</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Floating Chat IA -->
<a href="@Url.Action("Index", "IA")" class="floating-chat-btn">
    <i class="fas fa-robot"></i>
</a>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const cores = {
            primary: '#C0392B', primaryLight: '#E74C3C',
            success: '#10B981', warning: '#F59E0B',
            danger: '#EF4444', info: '#3B82F6',
            muted: '#9CA3AF'
        };

        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.color = '#6B7280';

        // Gastos por Evento
        const gastosNomes = @Html.Raw(ViewBag.GastosEventoNomes ?? "[]");
        const gastosValores = @Html.Raw(ViewBag.GastosEventoValores ?? "[]");
        if (gastosNomes.length > 0) {
            new Chart(document.getElementById('gastosEventoChart'), {
                type: 'bar',
                data: {
                    labels: gastosNomes,
                    datasets: [{
                        label: 'Gastos (R$)', data: gastosValores,
                        backgroundColor: [cores.primary, cores.primaryLight, cores.info, cores.warning, cores.success],
                        borderRadius: 8, borderSkipped: false, barPercentage: 0.6
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#F3F4F6' }, ticks: { callback: v => 'R$ ' + v.toLocaleString('pt-BR') } },
                        x: { grid: { display: false }, ticks: { maxRotation: 45 } }
                    }
                }
            });
        } else {
            document.getElementById('gastosEventoChart').parentElement.innerHTML = '<div class="empty-state"><i class="fas fa-chart-bar d-block"></i><p>Sem dados de gastos</p></div>';
        }

        // Status dos Convidados
        const convLabels = @Html.Raw(ViewBag.ConvidadosStatusLabels ?? "[]");
        const convValores = @Html.Raw(ViewBag.ConvidadosStatusValores ?? "[]");
        if (convValores.some(v => v > 0)) {
            new Chart(document.getElementById('convidadosChart'), {
                type: 'doughnut',
                data: {
                    labels: convLabels,
                    datasets: [{ data: convValores, backgroundColor: [cores.success, cores.warning, cores.danger], borderWidth: 0, spacing: 3 }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false, cutout: '68%',
                    plugins: { legend: { position: 'bottom', labels: { padding: 15, usePointStyle: true, pointStyleWidth: 10, font: { weight: '500' } } } }
                }
            });
        } else {
            document.getElementById('convidadosChart').parentElement.innerHTML = '<div class="empty-state"><i class="fas fa-users d-block"></i><p>Sem convidados</p></div>';
        }

        // Despesas Mensais
        const despMesLabels = @Html.Raw(ViewBag.DespesasMensaisLabels ?? "[]");
        const despMesValores = @Html.Raw(ViewBag.DespesasMensaisValores ?? "[]");
        if (despMesLabels.length > 0) {
            new Chart(document.getElementById('despesasMensaisChart'), {
                type: 'line',
                data: {
                    labels: despMesLabels,
                    datasets: [{
                        label: 'Despesas (R$)', data: despMesValores,
                        borderColor: cores.warning, backgroundColor: 'rgba(245, 158, 11, 0.08)',
                        fill: true, tension: 0.4, pointRadius: 4, pointBackgroundColor: cores.warning,
                        pointBorderColor: '#fff', pointBorderWidth: 2, borderWidth: 2.5
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#F3F4F6' }, ticks: { callback: v => 'R$ ' + v.toLocaleString('pt-BR') } },
                        x: { grid: { display: false } }
                    }
                }
            });
        } else {
            document.getElementById('despesasMensaisChart').parentElement.innerHTML = '<div class="empty-state"><i class="fas fa-chart-line d-block"></i><p>Sem despesas</p></div>';
        }

        // Tarefas Ring
        const tarefasCanvas = document.getElementById('tarefasRing');
        if (tarefasCanvas) {
            const ctx = tarefasCanvas.getContext('2d');
            const pct = @percentTarefas / 100;
            const cx = 70, cy = 70, r = 55, lw = 12;
            ctx.beginPath(); ctx.arc(cx, cy, r, 0, 2 * Math.PI);
            ctx.strokeStyle = '#F3F4F6'; ctx.lineWidth = lw; ctx.stroke();
            ctx.beginPath(); ctx.arc(cx, cy, r, -Math.PI / 2, -Math.PI / 2 + (2 * Math.PI * pct));
            ctx.strokeStyle = cores.info; ctx.lineWidth = lw; ctx.lineCap = 'round'; ctx.stroke();
        }

        // Pedidos
        const pedPend = @ViewBag.PedidosPendentes;
        const pedPago = @ViewBag.PedidosPagos;
        const pedEntr = @ViewBag.PedidosEntregues;
        if (pedPend + pedPago + pedEntr > 0) {
            new Chart(document.getElementById('pedidosChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Pendentes', 'Pagos', 'Entregues'],
                    datasets: [{ data: [pedPend, pedPago, pedEntr], backgroundColor: [cores.warning, cores.success, cores.info], borderWidth: 0, spacing: 2 }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false, cutout: '62%',
                    plugins: { legend: { position: 'bottom', labels: { padding: 8, usePointStyle: true, pointStyleWidth: 8, font: { size: 11, weight: '500' } } } }
                }
            });
        } else {
            document.getElementById('pedidosChart').parentElement.innerHTML = '<div class="empty-state"><i class="fas fa-shopping-cart d-block"></i><p>Sem pedidos</p></div>';
        }
    </script>
}
