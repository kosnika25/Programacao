@model ProjetoEventX.Models.OrganizadorDashboardViewModel

@{
    ViewData["Title"] = "Dashboard do Organizador";

    var totalEventos = (int?)(ViewBag.TotalEventos) ?? 0;
    var totalConvidados = (int?)(ViewBag.TotalConvidados) ?? 0;
    var convidadosConfirmados = (int?)(ViewBag.ConvidadosConfirmados) ?? 0;
    var eventosConcluidos = (int?)(ViewBag.EventosConcluidos) ?? 0;

    var totalOrc = (decimal?)(ViewBag.TotalOrcamento) ?? 0m;
    var totalGasto = (decimal?)(ViewBag.TotalDespesas) ?? 0m;
    var saldo = totalOrc - totalGasto;

    var saldoClass = saldo >= 0 ? "text-success" : "text-danger";
    var nomeOrganizador = Model?.Pessoa?.Nome ?? Model?.UserName ?? "Organizador";
    var fotoPerfil = string.IsNullOrWhiteSpace(Model?.FotoPerfilUrl) ? "/Images/user.png" : Model.FotoPerfilUrl;
    var totalEventosLista = Model?.Eventos?.Count() ?? 0;

    decimal percentualGasto = 0;
    if (totalOrc > 0)
    {
        percentualGasto = Math.Min(100, Math.Round((totalGasto / totalOrc) * 100, 2));
    }
}

@if (Model == null)
{
    <div class="alert alert-danger">Erro ao carregar dashboard.</div>
    return;
}

@section Styles {
    <style>
        .dash-shell {
            max-width: 1460px;
            margin: 0 auto;
        }

        .dash-grid {
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 18px;
        }

        .col-12 { grid-column: span 12; }
        .col-8 { grid-column: span 8; }
        .col-7 { grid-column: span 7; }
        .col-5 { grid-column: span 5; }
        .col-4 { grid-column: span 4; }
        .col-3 { grid-column: span 3; }

        .stripe-hero {
            position: relative;
            overflow: hidden;
            border-radius: 26px;
            padding: 26px 28px;
            background:
                radial-gradient(circle at top right, rgba(255,255,255,0.16), transparent 24%),
                radial-gradient(circle at bottom left, rgba(255,255,255,0.08), transparent 28%),
                linear-gradient(135deg, #7c1608 0%, #a92211 42%, #d54532 100%);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 24px 50px rgba(153, 32, 8, 0.22);
        }

        .stripe-hero::before {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            top: -90px;
            right: -70px;
            border-radius: 50%;
            background: rgba(255,255,255,0.08);
        }

        .stripe-hero-inner {
            position: relative;
            z-index: 1;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            border-radius: 999px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.14);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .stripe-hero h1 {
            margin: 14px 0 0;
            font-size: 42px;
            line-height: 1.02;
            font-weight: 800;
            letter-spacing: -.04em;
            max-width: 760px;
        }

        .stripe-hero p {
            margin: 14px 0 0;
            max-width: 720px;
            font-size: 15px;
            color: rgba(255,255,255,.86);
        }

        .hero-mini-stats {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 18px;
        }

        .hero-mini-stat {
            min-width: 180px;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 12px;
            border-radius: 16px;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.12);
            backdrop-filter: blur(8px);
        }

        .hero-mini-stat-icon {
            width: 34px;
            height: 34px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            background: rgba(255,255,255,.16);
            flex-shrink: 0;
        }

        .hero-mini-stat strong {
            display: block;
            font-size: 14px;
            line-height: 1.1;
        }

        .hero-mini-stat span {
            display: block;
            font-size: 11px;
            color: rgba(255,255,255,.78);
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: flex-end;
            align-items: flex-start;
            height: 100%;
        }

        .hero-actions .btn {
            min-height: 44px;
            min-width: 170px;
            border-radius: 14px;
            font-weight: 800;
            box-shadow: 0 10px 22px rgba(0,0,0,0.10);
        }

        .hero-actions .btn-light {
            color: #111827;
        }

        .metric-card-pro {
            position: relative;
            overflow: hidden;
            background: linear-gradient(180deg, #fff 0%, #fcfcfd 100%);
            border: 1px solid #edf1f6;
            border-radius: 22px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.06);
            transition: .22s ease;
        }

        .metric-card-pro:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.10);
        }

        .metric-card-pro-body {
            padding: 18px;
        }

        .metric-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
        }

        .metric-icon-pro {
            width: 54px;
            height: 54px;
            border-radius: 18px;
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 18px;
            flex-shrink: 0;
        }

        .metric-chip {
            padding: 5px 10px;
            border-radius: 999px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            color: #64748b;
            font-size: 11px;
            font-weight: 800;
        }

        .metric-value-pro {
            margin: 16px 0 4px;
            color: #0f172a;
            font-size: 22px;
            line-height: 1;
            font-weight: 800;
            letter-spacing: -.03em;
        }

        .metric-label-pro {
            color: #0f172a;
            font-size: 15px;
            font-weight: 700;
            margin: 0;
        }

        .metric-sub-pro {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid #eef2f7;
            color: #64748b;
            font-size: 13px;
            font-weight: 600;
        }

        .panel-card {
            background: #fff;
            border: 1px solid #edf1f6;
            border-radius: 24px;
            box-shadow: 0 14px 28px rgba(15, 23, 42, 0.06);
            overflow: hidden;
        }

        .panel-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 18px 20px;
            border-bottom: 1px solid #eef2f7;
            background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
        }

        .panel-title-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .panel-title-icon {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 16px;
            flex-shrink: 0;
        }

        .panel-title-wrap h5 {
            margin: 0;
            color: #0f172a;
            font-size: 16px;
            font-weight: 800;
        }

        .panel-title-wrap p {
            margin: 2px 0 0;
            color: #64748b;
            font-size: 13px;
        }

        .panel-body {
            padding: 20px;
        }

        .notion-event-card {
            position: relative;
            overflow: hidden;
            border-radius: 22px;
            padding: 20px;
            background:
                radial-gradient(circle at top right, rgba(59,130,246,0.10), transparent 26%),
                linear-gradient(180deg, #f8fbff 0%, #eff6ff 100%);
            border: 1px solid #dbeafe;
        }

        .notion-event-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            flex-wrap: wrap;
        }

        .notion-event-title {
            margin: 12px 0 4px;
            color: #0f172a;
            font-size: 20px;
            line-height: 1.1;
            font-weight: 800;
        }

        .notion-event-text {
            color: #64748b;
            font-size: 14px;
            font-weight: 600;
        }

        .event-meta-inline {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 14px;
        }

        .event-meta-inline span {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 12px;
            border-radius: 14px;
            background: #fff;
            border: 1px solid #e2e8f0;
            color: #334155;
            font-size: 13px;
            font-weight: 700;
        }

        .event-actions-inline {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 16px;
        }

        .event-actions-inline .btn {
            min-height: 42px;
            border-radius: 12px;
            font-weight: 800;
        }

        .linear-actions-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .linear-action {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px;
            background: #f8fafc;
            border: 1px solid #eef2f7;
            border-radius: 18px;
            transition: .2s ease;
            text-decoration: none;
        }

        .linear-action:hover {
            transform: translateY(-2px);
            background: #fff;
            box-shadow: 0 14px 28px rgba(15,23,42,0.08);
        }

        .linear-action-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 16px;
            flex-shrink: 0;
        }

        .linear-action strong {
            display: block;
            color: #0f172a;
            font-size: 15px;
            line-height: 1.1;
            font-weight: 800;
        }

        .linear-action span {
            display: block;
            margin-top: 3px;
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
        }

        .finance-stack {
            display: grid;
            gap: 12px;
        }

        .finance-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 14px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #eef2f7;
        }

        .finance-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 16px;
            flex-shrink: 0;
        }

        .finance-row p {
            margin: 0;
        }

        .finance-row .k {
            color: #64748b;
            font-size: 12px;
            font-weight: 700;
        }

        .finance-row .v {
            margin-top: 3px;
            color: #0f172a;
            font-size: 17px;
            line-height: 1.1;
            font-weight: 800;
            letter-spacing: -.02em;
        }

        .finance-progress {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid #eef2f7;
        }

        .finance-progress-top {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: center;
            margin-bottom: 8px;
        }

        .finance-bar {
            width: 100%;
            height: 10px;
            border-radius: 999px;
            background: #e5e7eb;
            overflow: hidden;
        }

        .finance-bar-fill {
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, #992008 0%, #E74C3C 100%);
        }

        .table-shell {
            overflow: hidden;
            border-radius: 18px;
            border: 1px solid #eef2f7;
            background: #fff;
        }

        .table-shell .table {
            margin: 0;
        }

        .table-shell .table thead th {
            background: #f8fafc;
            border-bottom: 1px solid #e5e7eb;
            color: #64748b;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .05em;
            font-weight: 800;
            padding-top: 14px;
            padding-bottom: 14px;
        }

        .table-shell .table tbody td {
            vertical-align: middle;
            padding-top: 14px;
            padding-bottom: 14px;
            border-color: #f1f5f9;
        }

        .table-shell .table tbody tr:hover {
            background: #fbfcfe;
        }

        .event-cell {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .event-cell strong {
            color: #111827;
            font-size: 15px;
        }

        .event-cell span {
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
        }

        .profile-block {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 16px;
        }

        .profile-side {
            padding: 18px;
            border-radius: 20px;
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            border: 1px solid #edf1f6;
        }

        .profile-top {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .profile-avatar-pro {
            width: 76px;
            height: 76px;
            object-fit: cover;
            border-radius: 50%;
            border: 4px solid #fff;
            box-shadow: 0 12px 24px rgba(15,23,42,0.10);
            flex-shrink: 0;
        }

        .profile-top h4 {
            margin: 0;
            color: #0f172a;
            font-size: 16px;
            font-weight: 800;
        }

        .profile-top p {
            margin: 3px 0 0;
            color: #64748b;
            font-size: 13px;
        }

        .profile-chips {
            margin-top: 16px;
            display: grid;
            gap: 10px;
        }

        .profile-chip {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 11px 12px;
            border-radius: 14px;
            background: #fff;
            border: 1px solid #eaeef4;
            color: #334155;
            font-size: 13px;
            font-weight: 700;
        }

        .profile-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .profile-grid-item {
            padding: 16px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #eef2f7;
        }

        .profile-grid-item small {
            display: block;
            margin-bottom: 4px;
            color: #64748b;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .05em;
            text-transform: uppercase;
        }

        .profile-grid-item strong {
            color: #0f172a;
            font-size: 15px;
            font-weight: 800;
        }

        .section-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 6px 11px;
            border-radius: 999px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            color: #475569;
            font-size: 12px;
            font-weight: 800;
        }

        @@media (max-width: 1199.98px) {
            .col-8, .col-7, .col-5, .col-4, .col-3 {
                grid-column: span 12;
            }

            .profile-block {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 991.98px) {
            .hero-actions {
                justify-content: flex-start;
                margin-top: 14px;
            }

            .linear-actions-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 767.98px) {
            .dash-grid {
                gap: 14px;
            }

            .stripe-hero {
                padding: 18px;
                border-radius: 22px;
            }

            .stripe-hero h1 {
                font-size: 30px;
            }

            .hero-mini-stat {
                width: 100%;
            }

            .metric-value-pro {
                font-size: 18px;
            }

            .profile-grid {
                grid-template-columns: 1fr;
            }

            .panel-card-header {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

<div class="dash-shell animate-in">
    <div class="dash-grid">
        <section class="col-12 stripe-hero">
            <div class="row g-4 stripe-hero-inner align-items-center">
                <div class="col-xl-8">
                    <span class="hero-badge">
                        <i class="fas fa-sparkles"></i>
                        Painel do organizador
                    </span>

                    <h1>Controle seus eventos com visão de produto e execução real.</h1>

                    <p>
                        Olá, <strong>@nomeOrganizador</strong>. Acompanhe seus eventos, convidados e orçamento em um painel mais estratégico, limpo e profissional.
                    </p>

                    <div class="hero-mini-stats">
                        <div class="hero-mini-stat">
                            <div class="hero-mini-stat-icon"><i class="fas fa-calendar-days"></i></div>
                            <div>
                                <strong>@totalEventos evento(s)</strong>
                                <span>Total em gestão</span>
                            </div>
                        </div>

                        <div class="hero-mini-stat">
                            <div class="hero-mini-stat-icon"><i class="fas fa-user-check"></i></div>
                            <div>
                                <strong>@convidadosConfirmados confirmados</strong>
                                <span>De @totalConvidados convidados</span>
                            </div>
                        </div>

                        <div class="hero-mini-stat">
                            <div class="hero-mini-stat-icon"><i class="fas fa-wallet"></i></div>
                            <div>
                                <strong>R$ @saldo.ToString("N2")</strong>
                                <span>Saldo disponível</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-4">
                    <div class="hero-actions">
                        <a asp-controller="Eventos" asp-action="Create" class="btn btn-light">
                            <i class="fas fa-plus me-2"></i>Novo Evento
                        </a>

                        <a asp-controller="TemplateConvite" asp-action="Index" class="btn btn-outline-light">
                            <i class="fas fa-envelope-open-text me-2"></i>Convites
                        </a>

                        <a asp-controller="Marketplace" asp-action="Index" class="btn btn-outline-light">
                            <i class="fas fa-store me-2"></i>Marketplace
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section class="col-3 metric-card-pro">
            <div class="metric-card-pro-body">
                <div class="metric-top">
                    <div class="metric-icon-pro" style="background: linear-gradient(135deg, #992008, #E74C3C);">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <span class="metric-chip">Visão geral</span>
                </div>

                <div class="metric-value-pro">@totalEventos</div>
                <p class="metric-label-pro">Eventos cadastrados</p>
                <div class="metric-sub-pro">Tudo o que você está gerenciando no momento.</div>
            </div>
        </section>

        <section class="col-3 metric-card-pro">
            <div class="metric-card-pro-body">
                <div class="metric-top">
                    <div class="metric-icon-pro" style="background: linear-gradient(135deg, #059669, #10B981);">
                        <i class="fas fa-users"></i>
                    </div>
                    <span class="metric-chip">Público</span>
                </div>

                <div class="metric-value-pro">@totalConvidados</div>
                <p class="metric-label-pro">Convidados</p>
                <div class="metric-sub-pro"><strong>@convidadosConfirmados</strong> com presença confirmada até agora.</div>
            </div>
        </section>

        <section class="col-3 metric-card-pro">
            <div class="metric-card-pro-body">
                <div class="metric-top">
                    <div class="metric-icon-pro" style="background: linear-gradient(135deg, #D97706, #F59E0B);">
                        <i class="fas fa-sack-dollar"></i>
                    </div>
                    <span class="metric-chip">Financeiro</span>
                </div>

                <div class="metric-value-pro">R$ @totalGasto.ToString("N2")</div>
                <p class="metric-label-pro">Total gasto</p>
                <div class="metric-sub-pro">Despesas já registradas no sistema.</div>
            </div>
        </section>

        <section class="col-3 metric-card-pro">
            <div class="metric-card-pro-body">
                <div class="metric-top">
                    <div class="metric-icon-pro" style="background: linear-gradient(135deg, #2563EB, #60A5FA);">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <span class="metric-chip">Histórico</span>
                </div>

                <div class="metric-value-pro">@eventosConcluidos</div>
                <p class="metric-label-pro">Concluídos</p>
                <div class="metric-sub-pro">Eventos já finalizados com sucesso.</div>
            </div>
        </section>

        <section class="col-7 panel-card">
            <div class="panel-card-header">
                <div class="panel-title-wrap">
                    <div class="panel-title-icon" style="background: linear-gradient(135deg, #2563EB, #60A5FA);">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <div>
                        <h5>Próximo evento em destaque</h5>
                        <p>Seu foco principal agora</p>
                    </div>
                </div>

                <span class="section-chip">
                    <i class="fas fa-bolt"></i>
                    Prioridade atual
                </span>
            </div>

            <div class="panel-body">
                @if (Model.ProximoEvento != null)
                {
                    <div class="notion-event-card">
                        <div class="notion-event-head">
                            <div>
                                <span class="badge badge-info">@Model.ProximoEvento.TipoEvento</span>
                                <h3 class="notion-event-title">@Model.ProximoEvento.NomeEvento</h3>
                                <div class="notion-event-text">Evento principal para acompanhamento imediato</div>
                            </div>

                            <span class="section-chip">
                                <i class="fas fa-star"></i>
                                Destaque
                            </span>
                        </div>

                        <div class="event-meta-inline">
                            <span>
                                <i class="fas fa-calendar-day"></i>
                                @Model.ProximoEvento.DataEvento.ToString("dd/MM/yyyy")
                            </span>

                            @if (!string.IsNullOrWhiteSpace(Model.ProximoEvento.HoraInicio))
                            {
                                <span>
                                    <i class="fas fa-clock"></i>
                                    @Model.ProximoEvento.HoraInicio
                                </span>
                            }

                            @if (!string.IsNullOrWhiteSpace(Model.ProximoEvento.Local))
                            {
                                <span>
                                    <i class="fas fa-location-dot"></i>
                                    @Model.ProximoEvento.Local
                                </span>
                            }
                        </div>

                        <div class="event-actions-inline">
                            <a asp-controller="Eventos" asp-action="Details" asp-route-id="@Model.ProximoEvento.Id" class="btn btn-eventx-primary btn-sm">
                                <i class="fas fa-eye me-1"></i>Ver detalhes
                            </a>

                            <a asp-controller="TemplateConvite" asp-action="Index" class="btn btn-eventx-outline btn-sm">
                                <i class="fas fa-envelope me-1"></i>Gerenciar convites
                            </a>

                            <a asp-controller="Orcamento" asp-action="Index" class="btn btn-eventx-outline btn-sm">
                                <i class="fas fa-file-invoice-dollar me-1"></i>Ir para orçamento
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-premium-state">
                        <i class="fas fa-calendar-plus"></i>
                        <h5 class="mb-2">Nenhum próximo evento cadastrado</h5>
                        <p class="mb-3">Crie um novo evento para começar sua operação dentro do EventX.</p>
                        <a asp-controller="Eventos" asp-action="Create" class="btn btn-eventx-primary btn-sm">
                            <i class="fas fa-plus me-1"></i>Criar evento
                        </a>
                    </div>
                }
            </div>
        </section>

        <section class="col-5 panel-card">
            <div class="panel-card-header">
                <div class="panel-title-wrap">
                    <div class="panel-title-icon" style="background: linear-gradient(135deg, #7C3AED, #A78BFA);">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <div>
                        <h5>Ações rápidas</h5>
                        <p>Fluxos que você usa com mais frequência</p>
                    </div>
                </div>
            </div>

            <div class="panel-body">
                <div class="linear-actions-grid">
                    <a asp-controller="Eventos" asp-action="Create" class="linear-action">
                        <div class="linear-action-icon" style="background: linear-gradient(135deg, #992008, #E74C3C);">
                            <i class="fas fa-calendar-plus"></i>
                        </div>
                        <div>
                            <strong>Novo evento</strong>
                            <span>Criar um novo planejamento</span>
                        </div>
                    </a>

                    <a asp-controller="TemplateConvite" asp-action="Index" class="linear-action">
                        <div class="linear-action-icon" style="background: linear-gradient(135deg, #2563EB, #60A5FA);">
                            <i class="fas fa-envelope-open-text"></i>
                        </div>
                        <div>
                            <strong>Convites</strong>
                            <span>Editar e enviar</span>
                        </div>
                    </a>

                    <a asp-controller="Marketplace" asp-action="Index" class="linear-action">
                        <div class="linear-action-icon" style="background: linear-gradient(135deg, #D97706, #F59E0B);">
                            <i class="fas fa-store"></i>
                        </div>
                        <div>
                            <strong>Marketplace</strong>
                            <span>Encontrar fornecedores</span>
                        </div>
                    </a>

                    <a asp-controller="Orcamento" asp-action="Index" class="linear-action">
                        <div class="linear-action-icon" style="background: linear-gradient(135deg, #059669, #34D399);">
                            <i class="fas fa-chart-pie"></i>
                        </div>
                        <div>
                            <strong>Orçamentos</strong>
                            <span>Acompanhar custos</span>
                        </div>
                    </a>
                </div>
            </div>
        </section>

        <section class="col-7 panel-card">
            <div class="panel-card-header">
                <div class="panel-title-wrap">
                    <div class="panel-title-icon" style="background: linear-gradient(135deg, #0f172a, #334155);">
                        <i class="fas fa-list-check"></i>
                    </div>
                    <div>
                        <h5>Eventos recentes</h5>
                        <p>Resumo operacional dos seus eventos</p>
                    </div>
                </div>

                <span class="section-chip">
                    <i class="fas fa-hashtag"></i>
                    @totalEventosLista registro(s)
                </span>
            </div>

            <div class="panel-body">
                @if (Model.Eventos != null && Model.Eventos.Any())
                {
                    <div class="table-shell">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Evento</th>
                                    <th>Data</th>
                                    <th>Tipo</th>
                                    <th class="text-end">Ação</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var evento in Model.Eventos.Take(8))
                                {
                                    <tr>
                                        <td>
                                            <div class="event-cell">
                                                <strong>@evento.NomeEvento</strong>
                                                @if (!string.IsNullOrWhiteSpace(evento.Local))
                                                {
                                                    <span><i class="fas fa-location-dot me-1"></i>@evento.Local</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="fw-semibold">@evento.DataEvento.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <span class="badge badge-pendente">@evento.TipoEvento</span>
                                        </td>
                                        <td class="text-end">
                                            <a asp-controller="Eventos" asp-action="Details" asp-route-id="@evento.Id" class="btn btn-eventx-outline btn-sm">
                                                <i class="fas fa-eye me-1"></i>Ver
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-premium-state">
                        <i class="fas fa-calendar-xmark"></i>
                        <h5 class="mb-2">Nenhum evento encontrado</h5>
                        <p class="mb-0">Assim que você criar eventos, eles aparecerão aqui com uma visão rápida.</p>
                    </div>
                }
            </div>
        </section>

        <section class="col-5 panel-card">
            <div class="panel-card-header">
                <div class="panel-title-wrap">
                    <div class="panel-title-icon" style="background: linear-gradient(135deg, #059669, #10B981);">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div>
                        <h5>Financeiro</h5>
                        <p>Orçamento, gasto e saldo em uma visão clara</p>
                    </div>
                </div>

                <span class="section-chip">
                    <i class="fas fa-wallet"></i>
                    @percentualGasto.ToString("N2")% usado
                </span>
            </div>

            <div class="panel-body">
                <div class="finance-stack">
                    <div class="finance-row">
                        <div class="finance-icon" style="background: linear-gradient(135deg, #2563EB, #60A5FA);">
                            <i class="fas fa-file-invoice-dollar"></i>
                        </div>
                        <div>
                            <p class="k">Orçamento total</p>
                            <p class="v">R$ @totalOrc.ToString("N2")</p>
                        </div>
                    </div>

                    <div class="finance-row">
                        <div class="finance-icon" style="background: linear-gradient(135deg, #D97706, #F59E0B);">
                            <i class="fas fa-coins"></i>
                        </div>
                        <div>
                            <p class="k">Total gasto</p>
                            <p class="v">R$ @totalGasto.ToString("N2")</p>
                        </div>
                    </div>

                    <div class="finance-row">
                        <div class="finance-icon" style="background: linear-gradient(135deg, #992008, #E74C3C);">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <div>
                            <p class="k">Saldo disponível</p>
                            <p class="v @saldoClass">R$ @saldo.ToString("N2")</p>
                        </div>
                    </div>
                </div>

                <div class="finance-progress">
                    <div class="finance-progress-top">
                        <small class="text-muted fw-semibold">Consumo do orçamento</small>
                        <small class="text-muted fw-bold">@percentualGasto.ToString("N2")%</small>
                    </div>

                    <div class="finance-bar">
                        <div class="finance-bar-fill" style="width:@percentualGasto.ToString(System.Globalization.CultureInfo.InvariantCulture)%"></div>
                    </div>

                    <div class="mt-3 text-muted" style="font-size: 13px; font-weight: 600;">
                        Quanto mais próximo de 100%, mais do orçamento já foi comprometido.
                    </div>
                </div>
            </div>
        </section>

        <section class="col-12 panel-card">
            <div class="panel-card-header">
                <div class="panel-title-wrap">
                    <div class="panel-title-icon" style="background: linear-gradient(135deg, #0f172a, #334155);">
                        <i class="fas fa-user-gear"></i>
                    </div>
                    <div>
                        <h5>Perfil do organizador</h5>
                        <p>Informações principais da sua conta</p>
                    </div>
                </div>

                <a asp-action="Profile" class="btn btn-eventx-primary btn-sm">
                    <i class="fas fa-pen me-1"></i>Editar perfil
                </a>
            </div>

            <div class="panel-body">
                <div class="profile-block">
                    <div class="profile-side">
                        <div class="profile-top">
                            <img src="@fotoPerfil" alt="Foto do perfil" class="profile-avatar-pro" />
                            <div>
                                <h4>@nomeOrganizador</h4>
                                <p>Organizador EventX</p>
                            </div>
                        </div>

                        <div class="profile-chips">
                            <div class="profile-chip">
                                <i class="fas fa-envelope"></i>
                                @(Model.Email ?? "-")
                            </div>

                            <div class="profile-chip">
                                <i class="fas fa-phone"></i>
                                @(Model.Pessoa?.Telefone ?? "-")
                            </div>

                            <div class="profile-chip">
                                <i class="fas fa-location-dot"></i>
                                @(Model.Pessoa?.Cidade ?? "-")
                            </div>
                        </div>
                    </div>

                    <div class="profile-grid">
                        <div class="profile-grid-item">
                            <small>Nome</small>
                            <strong>@(Model.Pessoa?.Nome ?? Model.UserName ?? "-")</strong>
                        </div>

                        <div class="profile-grid-item">
                            <small>Email</small>
                            <strong>@(Model.Email ?? "-")</strong>
                        </div>

                        <div class="profile-grid-item">
                            <small>Telefone</small>
                            <strong>@(Model.Pessoa?.Telefone ?? "-")</strong>
                        </div>

                        <div class="profile-grid-item">
                            <small>Cidade</small>
                            <strong>@(Model.Pessoa?.Cidade ?? "-")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>