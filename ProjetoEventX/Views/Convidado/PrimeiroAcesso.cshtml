@model ProjetoEventX.Models.PrimeiroAcessoViewModel
@{
    ViewBag.Title = "Primeiro Acesso - Troca de Senha";
}

<div class="container py-5 animate-in" style="max-width:420px;">
    <div class="card shadow-lg rounded-4 border-0">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <img src="/img/logo-eventx.svg" alt="EventX" style="height:48px;" class="mb-2" />
                <h2 class="fw-bold mb-2 text-primary">Bem-vindo ao EventX!</h2>
                <div class="text-muted mb-2">Este é seu primeiro acesso. Para sua segurança, defina uma nova senha.</div>
            </div>
            <form asp-action="PrimeiroAcesso" method="post" autocomplete="off">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                <div class="mb-3">
                    <label for="NovaSenha" class="form-label">Nova senha</label>
                    <input type="password" class="form-control form-control-lg rounded-pill" id="NovaSenha" name="NovaSenha" required placeholder="Digite sua nova senha" />
                    <span asp-validation-for="NovaSenha" class="invalid-feedback d-block"></span>
                </div>
                <div class="mb-3">
                    <label for="ConfirmacaoSenha" class="form-label">Confirme a nova senha</label>
                    <input type="password" class="form-control rounded-pill" id="ConfirmacaoSenha" name="ConfirmacaoSenha" required placeholder="Repita a senha" />
                    <span asp-validation-for="ConfirmacaoSenha" class="invalid-feedback d-block"></span>
                </div>
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <button type="submit" class="btn btn-primary btn-lg rounded-pill w-100 fw-bold shadow-sm mt-3">Salvar nova senha</button>
            </form>
        </div>
    </div>
</div>
