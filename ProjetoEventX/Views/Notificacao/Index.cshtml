@model IEnumerable<ProjetoEventX.Models.Notification>
@{
    ViewData["Title"] = "Notificações";
    var unread = ViewBag.UnreadCount as int? ?? 0;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-bell"></i> Notificações</h2>
        @if (unread > 0)
        {
            <button class="btn btn-outline-primary btn-sm" id="btnMarkAllRead">
                <i class="fas fa-check-double"></i> Marcar todas como lidas (@unread)
            </button>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-bell-slash fa-3x text-muted mb-3"></i>
            <p class="text-muted">Você ainda não tem notificações.</p>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var n in Model)
            {
                var bgClass = n.IsRead ? "" : "list-group-item-light";
                var icon = n.Type switch
                {
                    "RespostaOrcamento" => "fas fa-file-invoice-dollar text-primary",
                    "NovaMensagem" => "fas fa-comment-dots text-info",
                    "PropostaAceita" => "fas fa-check-circle text-success",
                    "PropostaRecusada" => "fas fa-times-circle text-danger",
                    "NovoPedido" => "fas fa-shopping-cart text-warning",
                    "PagamentoConfirmado" => "fas fa-credit-card text-success",
                    "ConfirmacaoPresenca" => "fas fa-user-check text-primary",
                    _ => "fas fa-bell text-secondary"
                };
                var link = n.Link ?? "#";

                <a href="@link" class="list-group-item list-group-item-action @bgClass notification-row" data-id="@n.Id">
                    <div class="d-flex align-items-start">
                        <i class="@icon me-3 mt-1 fa-lg"></i>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <h6 class="mb-1 @(n.IsRead ? "" : "fw-bold")">@n.Title</h6>
                                <small class="text-muted">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <p class="mb-1 text-muted" style="font-size: 0.9rem;">@n.Message</p>
                            <small class="text-muted"><i class="fas fa-tag me-1"></i>@n.Type</small>
                        </div>
                        @if (!n.IsRead)
                        {
                            <span class="ms-2 mt-1"><i class="fas fa-circle text-primary" style="font-size: 0.5rem;"></i></span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    // Marcar individual ao clicar
    $(document).on('click', '.notification-row', function(e) {
        var id = $(this).data('id');
        var link = $(this).attr('href');
        if (link && link !== '#') {
            e.preventDefault();
            $.post('/Notificacao/MarkAsRead/' + id, function() {
                window.location.href = link;
            });
        }
    });

    // Marcar todas como lidas
    $('#btnMarkAllRead').on('click', function() {
        $.post('/Notificacao/MarkAllAsRead', function() {
            location.reload();
        });
    });
</script>
}
