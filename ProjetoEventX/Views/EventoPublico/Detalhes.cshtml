@model ProjetoEventX.Models.Evento

@{
    Layout = null;
    var nomeEvento = Model.NomeEvento;
    var descricao = Model.DescricaoEvento;
    var data = Model.DataEvento;
    var horaInicio = Model.HoraInicio;
    var horaFim = Model.HoraFim;
    var local = Model.Local;
    var imagemCapa = Model.ImagemCapa;
    var organizador = Model.Organizador?.Pessoa;
    var totalConfirmados = Model.ListasConvidados?.Count(lc => lc.ConfirmaPresenca == "Confirmado") ?? 0;
    var enderecoEncoded = local != null ? Uri.EscapeDataString(local.EnderecoLocal) : "";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@nomeEvento - EventX</title>
    <meta name="description" content="@descricao" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --primary-light: #a5b4fc;
            --accent: #f59e0b;
            --bg-dark: #0f172a;
            --bg-card: #1e293b;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border: #334155;
            --success: #22c55e;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            min-height: 100vh;
        }

        /* Hero Section */
        .hero-section {
            position: relative;
            min-height: 70vh;
            display: flex;
            align-items: flex-end;
            overflow: hidden;
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            background: url('@(imagemCapa ?? "/Images/default-event-cover.jpg")') center/cover no-repeat;
        }

        .hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, var(--bg-dark) 0%, rgba(15,23,42,0.6) 40%, rgba(15,23,42,0.2) 100%);
        }

        .hero-content {
            position: relative;
            z-index: 2;
            width: 100%;
            padding: 3rem 0;
        }

        .event-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(99, 102, 241, 0.2);
            border: 1px solid rgba(99, 102, 241, 0.3);
            color: var(--primary-light);
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 1rem;
            backdrop-filter: blur(10px);
        }

        .event-title {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, var(--primary-light) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .event-subtitle {
            font-size: 1.15rem;
            color: var(--text-secondary);
            max-width: 600px;
            line-height: 1.6;
        }

        /* Info Cards */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
            margin: -2rem 0 2rem;
            position: relative;
            z-index: 3;
        }

        .info-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: transform 0.2s, border-color 0.2s;
        }

        .info-card:hover {
            transform: translateY(-2px);
            border-color: var(--primary);
        }

        .info-card .icon-wrap {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .icon-wrap.date { background: rgba(99,102,241,0.15); color: var(--primary-light); }
        .icon-wrap.time { background: rgba(245,158,11,0.15); color: var(--accent); }
        .icon-wrap.location { background: rgba(34,197,94,0.15); color: var(--success); }
        .icon-wrap.people { background: rgba(236,72,153,0.15); color: #f472b6; }

        .info-card .info-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.15rem;
        }

        .info-card .info-value {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Main Content */
        .content-section {
            padding: 3rem 0;
        }

        .section-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 1.5rem;
        }

        .section-title {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .section-title i {
            color: var(--primary-light);
        }

        .description-text {
            color: var(--text-secondary);
            line-height: 1.8;
            font-size: 1.05rem;
        }

        /* Map */
        .map-container {
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border);
            height: 300px;
        }

        .map-container iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }

        /* CTA Section */
        .cta-card {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            border: none;
            border-radius: 20px;
            padding: 2.5rem;
            text-align: center;
        }

        .cta-card h3 {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .cta-card p {
            color: rgba(255,255,255,0.8);
            margin-bottom: 1.5rem;
        }

        .btn-cta {
            background: #fff;
            color: var(--primary-dark);
            border: none;
            padding: 0.9rem 2.5rem;
            border-radius: 50px;
            font-size: 1.05rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
            color: var(--primary-dark);
        }

        /* Organizer */
        .organizer-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .organizer-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: 700;
            color: #fff;
        }

        .organizer-name { font-weight: 600; }
        .organizer-role { font-size: 0.85rem; color: var(--text-secondary); }

        /* Modal */
        .modal-content {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            color: var(--text-primary);
        }

        .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 1.5rem 2rem;
        }

        .modal-body { padding: 2rem; }

        .modal-footer { border-top: 1px solid var(--border); padding: 1rem 2rem; }

        .form-control-dark {
            background: var(--bg-dark);
            border: 1px solid var(--border);
            color: var(--text-primary);
            border-radius: 12px;
            padding: 0.75rem 1rem;
        }

        .form-control-dark:focus {
            background: var(--bg-dark);
            border-color: var(--primary);
            color: var(--text-primary);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
        }

        .form-control-dark::placeholder {
            color: var(--text-secondary);
        }

        .btn-confirm {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            color: #fff;
            padding: 0.75rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            width: 100%;
            font-size: 1.05rem;
        }

        .btn-confirm:hover {
            opacity: 0.9;
            color: #fff;
        }

        /* Alert overrides */
        .alert-dark-success {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.3);
            color: var(--success);
            border-radius: 12px;
        }

        .alert-dark-info {
            background: rgba(99,102,241,0.1);
            border: 1px solid rgba(99,102,241,0.3);
            color: var(--primary-light);
            border-radius: 12px;
        }

        /* Footer */
        .public-footer {
            padding: 2rem 0;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.9rem;
            border-top: 1px solid var(--border);
            margin-top: 3rem;
        }

        .public-footer a {
            color: var(--primary-light);
            text-decoration: none;
        }

        /* Countdown */
        .countdown-grid {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin: 1rem 0;
        }

        .countdown-item {
            text-align: center;
        }

        .countdown-number {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-light), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
        }

        .countdown-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Share buttons */
        .share-buttons {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .share-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-secondary);
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }

        .share-btn:hover {
            border-color: var(--primary);
            color: var(--primary-light);
            background: rgba(99,102,241,0.05);
        }

        @@media (max-width: 768px) {
            .event-title { font-size: 2.2rem; }
            .hero-section { min-height: 50vh; }
            .info-grid { grid-template-columns: 1fr 1fr; }
            .countdown-number { font-size: 1.8rem; }
        }

        @@media (max-width: 480px) {
            .info-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-dark-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-dark-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle me-2"></i> @TempData["InfoMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <!-- Hero -->
    <section class="hero-section">
        <div class="hero-bg"></div>
            <div class="hero-content">
                <div class="container">
                    <div class="event-badge">
                        <i class="fas fa-calendar-star"></i> @Model.TipoEvento
                    </div>
                    <h1 class="event-title">@nomeEvento
                        @if (Model.TipoEvento == "Premium")
                        {
                            <span class="badge-eventx badge-premium ms-2" title="Evento Premium"><i class="fas fa-star"></i> Premium</span>
                        }
                    </h1>
                <p class="event-subtitle">@(descricao.Length > 180 ? descricao.Substring(0, 180) + "..." : descricao)</p>
            </div>
        </div>
    </section>

    <!-- Info Cards -->
    <div class="container">
        <div class="info-grid">
            <div class="info-card">
                <div class="icon-wrap date"><i class="fas fa-calendar-day"></i></div>
                <div>
                    <div class="info-label">Data</div>
                    <div class="info-value">@data.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))</div>
                </div>
            </div>
            <div class="info-card">
                <div class="icon-wrap time"><i class="fas fa-clock"></i></div>
                <div>
                    <div class="info-label">Horário</div>
                    <div class="info-value">@horaInicio - @horaFim</div>
                </div>
            </div>
            @if (local != null)
            {
                <div class="info-card">
                    <div class="icon-wrap location"><i class="fas fa-map-marker-alt"></i></div>
                    <div>
                        <div class="info-label">Local</div>
                        <div class="info-value">@local.NomeLocal</div>
                    </div>
                </div>
            }
            <div class="info-card">
                <div class="icon-wrap people"><i class="fas fa-users"></i></div>
                <div>
                    <div class="info-label">Confirmados</div>
                    <div class="info-value">@totalConfirmados / @Model.PublicoEstimado</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="container content-section">
        <div class="row g-4">
            <div class="col-lg-8">
                <!-- Countdown -->
                @if (data > DateTime.UtcNow)
                {
                    <div class="section-card text-center">
                        <h5 class="section-title justify-content-center">
                            <i class="fas fa-hourglass-half"></i> Contagem regressiva
                        </h5>
                        <div class="countdown-grid" id="countdown"
                             data-target="@data.ToString("yyyy-MM-ddTHH:mm:ss")">
                            <div class="countdown-item">
                                <div class="countdown-number" id="cd-days">--</div>
                                <div class="countdown-label">Dias</div>
                            </div>
                            <div class="countdown-item">
                                <div class="countdown-number" id="cd-hours">--</div>
                                <div class="countdown-label">Horas</div>
                            </div>
                            <div class="countdown-item">
                                <div class="countdown-number" id="cd-minutes">--</div>
                                <div class="countdown-label">Minutos</div>
                            </div>
                            <div class="countdown-item">
                                <div class="countdown-number" id="cd-seconds">--</div>
                                <div class="countdown-label">Segundos</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Description -->
                <div class="section-card">
                    <h5 class="section-title">
                        <i class="fas fa-align-left"></i> Sobre o evento
                    </h5>
                    <div class="description-text">
                        @Html.Raw(descricao.Replace("\n", "<br/>"))
                    </div>
                </div>

                <!-- Map -->
                @if (local != null && !string.IsNullOrWhiteSpace(local.EnderecoLocal))
                {
                    <div class="section-card">
                        <h5 class="section-title">
                            <i class="fas fa-map-marked-alt"></i> Localização
                        </h5>
                        <p class="text-secondary mb-3">
                            <i class="fas fa-map-pin me-2"></i>@local.EnderecoLocal
                        </p>
                        <div class="map-container">
                            <iframe
                                src="https://maps.google.com/maps?q=@(enderecoEncoded)&t=&z=15&ie=UTF8&iwloc=&output=embed"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                            </iframe>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <!-- CTA -->
                <div class="cta-card mb-4">
                    <h3><i class="fas fa-ticket-alt me-2"></i>Participe!</h3>
                    <p>Garanta sua presença neste evento incrível</p>
                    <button class="btn-cta" data-bs-toggle="modal" data-bs-target="#confirmarModal">
                        <i class="fas fa-check-circle"></i> Confirmar Presença
                    </button>
                </div>

                <!-- Organizer -->
                @if (organizador != null)
                {
                    <div class="section-card">
                        <h5 class="section-title">
                            <i class="fas fa-user-tie"></i> Organizador
                        </h5>
                        <div class="organizer-info">
                            <div class="organizer-avatar">
                                @(organizador.Nome?.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <div class="organizer-name">@organizador.Nome</div>
                                <div class="organizer-role">Organizador do evento</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Share -->
                <div class="section-card">
                    <h5 class="section-title">
                        <i class="fas fa-share-alt"></i> Compartilhar
                    </h5>
                    <div class="share-buttons">
                        <a href="https://wa.me/?text=@Uri.EscapeDataString(nomeEvento + " - Confira este evento! " + Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"
                           target="_blank" rel="noopener noreferrer" class="share-btn">
                            <i class="fab fa-whatsapp"></i> WhatsApp
                        </a>
                        <button class="share-btn" onclick="copyLink()">
                            <i class="fas fa-link"></i> Copiar Link
                        </button>
                    </div>
                </div>

                <!-- Event Details -->
                <div class="section-card">
                    <h5 class="section-title">
                        <i class="fas fa-info-circle"></i> Detalhes
                    </h5>
                    <ul class="list-unstyled" style="color: var(--text-secondary);">
                        <li class="mb-2">
                            <i class="fas fa-tag me-2" style="color:var(--primary-light)"></i>
                            <strong>Tipo:</strong> @Model.TipoEvento
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-signal me-2" style="color:var(--accent)"></i>
                            <strong>Status:</strong> @Model.StatusEvento
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-users me-2" style="color:var(--success)"></i>
                            <strong>Capacidade:</strong> @Model.PublicoEstimado pessoas
                        </li>
                        @if (local != null)
                        {
                            <li class="mb-2">
                                <i class="fas fa-building me-2" style="color:#f472b6"></i>
                                <strong>Tipo de local:</strong> @local.TipoLocal
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="public-footer">
        <div class="container">
            <p>Evento criado com <a href="/">EventX</a> — A plataforma de gestão de eventos</p>
        </div>
    </footer>

    <!-- Modal Confirmar Presença -->
    <div class="modal fade" id="confirmarModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-check-circle me-2" style="color:var(--primary-light)"></i>
                        Confirmar Presença
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="/evento/@Model.Slug/confirmar">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <p class="text-secondary mb-4">Preencha seus dados para confirmar presença em <strong style="color:var(--text-primary)">@nomeEvento</strong></p>
                        <div class="mb-3">
                            <label class="form-label">Nome completo</label>
                            <input type="text" name="nome" class="form-control form-control-dark" placeholder="Seu nome" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            <input type="email" name="email" class="form-control form-control-dark" placeholder="seu@email.com" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-confirm">
                            <i class="fas fa-check me-2"></i> Confirmar presença
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Countdown
        (function () {
            const el = document.getElementById('countdown');
            if (!el) return;
            const target = new Date(el.dataset.target).getTime();

            function update() {
                const now = Date.now();
                const diff = target - now;
                if (diff <= 0) {
                    document.getElementById('cd-days').textContent = '0';
                    document.getElementById('cd-hours').textContent = '0';
                    document.getElementById('cd-minutes').textContent = '0';
                    document.getElementById('cd-seconds').textContent = '0';
                    return;
                }
                document.getElementById('cd-days').textContent = Math.floor(diff / 86400000);
                document.getElementById('cd-hours').textContent = Math.floor((diff % 86400000) / 3600000);
                document.getElementById('cd-minutes').textContent = Math.floor((diff % 3600000) / 60000);
                document.getElementById('cd-seconds').textContent = Math.floor((diff % 60000) / 1000);
            }

            update();
            setInterval(update, 1000);
        })();

        // Copy link
        function copyLink() {
            navigator.clipboard.writeText(window.location.href).then(() => {
                const btn = event.currentTarget;
                const original = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-check"></i> Copiado!';
                setTimeout(() => btn.innerHTML = original, 2000);
            });
        }
    </script>
</body>
</html>
