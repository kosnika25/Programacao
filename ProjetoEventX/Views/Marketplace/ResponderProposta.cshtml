@model ProjetoEventX.Models.RespostaPropostaViewModel
@{
    ViewData["Title"] = "Responder Solicitação";
    var solicitacao = ViewBag.Solicitacao as ProjetoEventX.Models.SolicitacaoOrcamento;
    var fornecedor = ViewBag.Fornecedor as ProjetoEventX.Models.Fornecedor;
}

<style>
    .resposta-section {
        background: #f5f0eb;
        min-height: 80vh;
        padding: 2rem 0 3rem;
    }
    .resposta-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        padding: 2rem;
    }
    .resposta-card h3 {
        color: #8B0000;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .solicitacao-info-banner {
        background: linear-gradient(135deg, #8B0000, #b22222);
        border-radius: 14px;
        padding: 1.5rem;
        color: #fff;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .solicitacao-info-banner .avatar {
        width: 55px;
        height: 55px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    .solicitacao-info-banner h5 { margin: 0; font-weight: 700; }
    .solicitacao-info-banner .info-sub { opacity: 0.85; font-size: 0.9rem; }
    .form-label-custom {
        font-weight: 600;
        color: #555;
        font-size: 0.9rem;
        margin-bottom: 0.3rem;
    }
    .form-control-custom {
        border: 1px solid #e0d6cc;
        border-radius: 12px;
        padding: 0.7rem 1rem;
        background: #faf8f5;
        transition: all 0.3s;
    }
    .form-control-custom:focus {
        border-color: #8B0000;
        box-shadow: 0 0 0 3px rgba(139,0,0,0.1);
        background: #fff;
    }
    .btn-enviar {
        background: #8B0000;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 0.8rem 2.5rem;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s;
    }
    .btn-enviar:hover { background: #a00000; color: #fff; transform: translateY(-2px); }
    .btn-cancelar {
        background: none;
        color: #8B0000;
        border: 2px solid #8B0000;
        border-radius: 12px;
        padding: 0.8rem 2rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }
    .btn-cancelar:hover { background: #8B0000; color: #fff; }
    .campo-obrigatorio { color: #dc3545; }
    .dica-texto { font-size: 0.8rem; color: #999; margin-top: 0.3rem; }
</style>

<section class="resposta-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <a asp-action="MinhasSolicitacoes" class="text-decoration-none d-inline-block mb-3" style="color: #8B0000;">
                    <i class="fas fa-arrow-left"></i> Voltar ao painel de solicitações
                </a>

                <div class="resposta-card">
                    <h3><i class="fas fa-reply"></i> Responder Solicitação</h3>
                    <p class="text-muted mb-3">Preencha os campos abaixo para enviar sua proposta comercial</p>

                    @if (solicitacao != null)
                    {
                        <div class="solicitacao-info-banner">
                            <div class="avatar"><i class="fas fa-file-invoice-dollar"></i></div>
                            <div>
                                <h5>@solicitacao.Titulo</h5>
                                <div class="info-sub">
                                    <i class="fas fa-calendar-alt"></i> @solicitacao.DataEvento?.ToString("dd/MM/yyyy") &nbsp;|&nbsp;
                                    <i class="fas fa-users"></i> @solicitacao.QuantidadeConvidados &nbsp;|&nbsp;
                                    <i class="fas fa-tag"></i> @solicitacao.TipoServicoDesejado
                                </div>
                            </div>
                        </div>
                    }

                    <form method="post" asp-action="ResponderProposta">
                        <input type="hidden" name="solicitacaoId" value="@solicitacao?.Id" />
                        <input type="hidden" name="fornecedorId" value="@fornecedor?.Id" />

                        <div class="mb-3">
                            <label class="form-label-custom">Valor Proposto (R$) <span class="campo-obrigatorio">*</span></label>
                            <input type="number" name="valorProposto" class="form-control form-control-custom" required
                                   step="0.01" min="0" placeholder="Valor do orçamento" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label-custom">Descrição da Proposta <span class="campo-obrigatorio">*</span></label>
                            <textarea name="descricaoProposta" class="form-control form-control-custom" rows="4" required
                                      maxlength="2000" placeholder="Detalhe sua proposta, condições, diferenciais..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label-custom">Prazo de Entrega <span class="campo-obrigatorio">*</span></label>
                            <input type="text" name="prazoEntrega" class="form-control form-control-custom" required
                                   maxlength="100" placeholder="Ex: 10 dias, 2 semanas, até 30/04/2026" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label-custom">Observações</label>
                            <textarea name="observacoes" class="form-control form-control-custom" rows="2"
                                      maxlength="500" placeholder="Informações adicionais, condições especiais..."></textarea>
                        </div>

                        <input type="hidden" name="status" value="Respondido" />

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-enviar">
                                <i class="fas fa-paper-plane"></i> Enviar Proposta
                            </button>
                            <a asp-action="MinhasSolicitacoes" class="btn btn-cancelar">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
