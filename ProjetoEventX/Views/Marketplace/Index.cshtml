@model IEnumerable<ProjetoEventX.Models.Fornecedor>
@{
    ViewData["Title"] = "Marketplace de Fornecedores";
    var categorias = ViewBag.Categorias as List<string> ?? new List<string>();
    var ufs = ViewBag.UFs as List<string> ?? new List<string>();
}

<!-- Hero -->
<section class="marketplace-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1><i class="fas fa-store me-2"></i>Marketplace de Fornecedores</h1>
                <p>Encontre os melhores fornecedores para o seu evento. Compare preços, avaliações e solicite orçamentos diretamente.</p>
                <div class="stats-bar">
                    <div class="stat-item">
                        <div class="stat-num">@ViewBag.TotalFornecedores</div>
                        <div class="stat-label">Fornecedores</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-num">@(categorias.Count)</div>
                        <div class="stat-label">Categorias</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-num">@(ufs.Count)</div>
                        <div class="stat-label">Estados</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <form method="get" asp-action="Index" class="search-box">
                    <div class="input-group">
                        <input type="text" name="busca" class="form-control" placeholder="Buscar fornecedores, serviços..."
                               value="@ViewBag.FiltroBusca" />
                        <button type="submit" class="btn btn-buscar ms-2">
                            <i class="fas fa-search me-1"></i> Buscar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<div class="container" style="margin-bottom: 3rem;">
    <div class="row">
        <!-- Filtros Laterais -->
        <div class="col-lg-3 mb-4">
            <form method="get" asp-action="Index" class="filtros-lateral" id="filtrosForm">
                <!-- Preservar busca -->
                <input type="hidden" name="busca" value="@ViewBag.FiltroBusca" />

                <h5><i class="fas fa-sliders-h"></i> Filtros</h5>

                <div class="filtro-grupo">
                    <label><i class="fas fa-tags"></i> Categoria</label>
                    <select name="categoria" class="form-select">
                        <option value="">Todas as categorias</option>
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat" selected="@(ViewBag.FiltroCategoria == cat)">@cat</option>
                        }
                    </select>
                </div>

                <div class="filtro-grupo">
                    <label><i class="fas fa-map-marker-alt"></i> Estado (UF)</label>
                    <select name="uf" class="form-select">
                        <option value="">Todos os estados</option>
                        @foreach (var estado in ufs)
                        {
                            <option value="@estado" selected="@(ViewBag.FiltroUF == estado)">@estado</option>
                        }
                    </select>
                </div>

                <div class="filtro-grupo">
                    <label><i class="fas fa-city"></i> Cidade</label>
                    <input type="text" name="localizacao" placeholder="Digite a cidade..."
                           value="@ViewBag.FiltroLocalizacao" />
                </div>

                <div class="filtro-grupo">
                    <label><i class="fas fa-dollar-sign"></i> Faixa de Preço</label>
                    <div class="d-flex gap-2">
                        <input type="number" name="precoMin" placeholder="Mín"
                               value="@ViewBag.FiltroPrecoMin" step="0.01" min="0" style="width:48%;" />
                        <input type="number" name="precoMax" placeholder="Máx"
                               value="@ViewBag.FiltroPrecoMax" step="0.01" min="0" style="width:48%;" />
                    </div>
                </div>

                <div class="filtro-grupo">
                    <label><i class="fas fa-star"></i> Avaliação Mínima</label>
                    <div class="star-filter">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var isActive = ViewBag.FiltroAvaliacaoMin != null && (int)ViewBag.FiltroAvaliacaoMin == i;
                            <button type="button" class="star-btn @(isActive ? "active" : "")" data-rating="@i" onclick="setRating(@i)">
                                @i <i class="fas fa-star"></i>
                            </button>
                        }
                    </div>
                    <input type="hidden" name="avaliacaoMin" id="avaliacaoMinInput" value="@ViewBag.FiltroAvaliacaoMin" />
                </div>

                <button type="submit" class="btn btn-filtrar">
                    <i class="fas fa-filter"></i> Aplicar Filtros
                </button>
                <a asp-action="Index" class="btn btn-limpar">
                    <i class="fas fa-times"></i> Limpar Filtros
                </a>
            </form>
        </div>

        <!-- Lista de Fornecedores -->
        <div class="col-lg-9">
            <div class="resultados-header">
                <div>
                    <h5>Fornecedores Encontrados <span class="badge">@ViewBag.TotalFornecedores</span></h5>
                </div>
                <div>
                    @{
                        var ordenarAtual = (string?)ViewBag.FiltroOrdenar ?? "";
                    }
                    <select class="ordenar-select" onchange="ordenarPor(this.value)">
                        @if (string.IsNullOrEmpty(ordenarAtual))
                        {
                            <option value="" disabled selected>Ordenar por</option>
                        }
                        else
                        {
                            <option value="" disabled>Ordenar por</option>
                        }
                        @foreach (var opt in new[] {
                            ("avaliacao", "Melhor avaliação"),
                            ("preco_asc", "Menor preço"),
                            ("preco_desc", "Maior preço"),
                            ("nome", "Nome A-Z"),
                            ("recente", "Mais recentes")
                        })
                        {
                            if (ordenarAtual == opt.Item1)
                            {
                                <option value="@opt.Item1" selected>@opt.Item2</option>
                            }
                            else
                            {
                                <option value="@opt.Item1">@opt.Item2</option>
                            }
                        }
                    </select>
                </div>
            </div>

            @if (Model.Any())
            {
                <div class="row">
                    @foreach (var fornecedor in Model)
                    {
                        var precoMin = fornecedor.Produtos.Any() ? fornecedor.Produtos.Min(p => p.Preco) : 0;
                        var precoMax = fornecedor.Produtos.Any() ? fornecedor.Produtos.Max(p => p.Preco) : 0;
                        var totalAvaliacoes = fornecedor.Avaliacoes?.Count ?? 0;

                        <div class="col-lg-6 col-xl-4 mb-4">
                            <div class="fornecedor-card fornecedor-card-hover">
                                <div class="fornecedor-card-header">
                                    <div class="fornecedor-avatar">
                                        <i class="fas fa-store"></i>
                                    </div>
                                    <h5>@fornecedor.Pessoa?.Nome
                                        @if (fornecedor.Cnpj != null && fornecedor.Cnpj.Length > 0)
                                        {
                                            <span class="badge-eventx badge-verificado ms-2" title="Fornecedor verificado"><i class="fas fa-check-circle"></i></span>
                                        }
                                    </h5>
                                    <span class="categoria-badge">@fornecedor.TipoServico</span>
                                </div>
                                <div class="fornecedor-card-body">
                                    <div class="fornecedor-info-row">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <span>@fornecedor.Cidade, @fornecedor.UF</span>
                                    </div>
                                    <div class="fornecedor-info-row">
                                        <i class="fas fa-star star-gold"></i>
                                        <span class="fornecedor-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= Math.Round(fornecedor.AvaliacaoMedia))
                                                {
                                                    <i class="fas fa-star"></i>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-star empty"></i>
                                                }
                                            }
                                            <span class="text-muted" style="margin-left: 0.3rem;">
                                                @fornecedor.AvaliacaoMedia.ToString("N1")
                                                (@totalAvaliacoes @(totalAvaliacoes == 1 ? "avaliação" : "avaliações"))
                                            </span>
                                        </span>
                                    </div>
                                    <div class="fornecedor-info-row">
                                        <i class="fas fa-box"></i>
                                        <span>@fornecedor.Produtos.Count @(fornecedor.Produtos.Count == 1 ? "produto" : "produtos")</span>
                                    </div>

                                    <div class="preco-range">
                                        <div>
                                            <div class="label">A partir de</div>
                                            <div class="valor">R$ @precoMin.ToString("N2")</div>
                                        </div>
                                        @if (precoMin != precoMax)
                                        {
                                            <div style="text-align: right;">
                                                <div class="label">Até</div>
                                                <div class="valor">R$ @precoMax.ToString("N2")</div>
                                            </div>
                                        }
                                    </div>

                                    <div class="produtos-tags">
                                        @foreach (var produto in fornecedor.Produtos.Take(3))
                                        {
                                            <span class="produto-tag">@produto.Nome</span>
                                        }
                                        @if (fornecedor.Produtos.Count > 3)
                                        {
                                            <span class="produto-tag">+@(fornecedor.Produtos.Count - 3) mais</span>
                                        }
                                    </div>
                                </div>
                                <div class="fornecedor-card-footer">
                                    <a asp-action="DetalhesFornecedor" asp-route-id="@fornecedor.Id" class="btn-ver-perfil">
                                        <i class="fas fa-eye"></i> Ver Perfil
                                    </a>
                                    <a asp-action="SolicitarOrcamento" asp-route-id="@fornecedor.Id" class="btn-orcamento">
                                        <i class="fas fa-file-invoice-dollar"></i> Orçamento
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="eventx-empty-state">
                    <div class="eventx-empty-state-icon">
                        <i class="fas fa-search"></i>
                    </div>
                    <h4>Nenhum fornecedor encontrado</h4>
                    <p>Tente ajustar os filtros ou faça uma busca diferente.</p>
                    <a asp-action="Index" class="btn btn-eventx-action">
                        <i class="fas fa-undo"></i> Ver todos os fornecedores
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setRating(rating) {
            const input = document.getElementById('avaliacaoMinInput');
            const buttons = document.querySelectorAll('.star-btn');

            if (input.value == rating) {
                input.value = '';
                buttons.forEach(b => b.classList.remove('active'));
            } else {
                input.value = rating;
                buttons.forEach(b => {
                    b.classList.toggle('active', parseInt(b.dataset.rating) === rating);
                });
            }
        }

        function ordenarPor(valor) {
            const url = new URL(window.location.href);
            url.searchParams.set('ordenar', valor);
            window.location.href = url.toString();
        }
    </script>
}
