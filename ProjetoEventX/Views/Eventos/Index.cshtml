@model IEnumerable<ProjetoEventX.Models.Evento>

@{
    ViewData["Title"] = "Meus Eventos";
    var tipoUsuario = User.Claims.FirstOrDefault(c => c.Type == "TipoUsuario")?.Value ?? "";
    var isOrganizador = tipoUsuario == "Organizador";
}

@{ ViewData["HeroIcon"] = "fas fa-calendar-alt"; ViewData["HeroTitle"] = "Eventos"; ViewData["HeroSubtitle"] = "Organize, acompanhe status e mantenha sua operação de eventos centralizada."; }
@await Html.PartialAsync("_PageHero")

<div class="row mb-4">
    <div class="col-md-8">
        <h1 class="text-eventx-primary">
            <i class="fas fa-calendar-alt"></i> Meus Eventos
        </h1>
        <p class="text-muted">Gerencie todos os seus eventos em um só lugar</p>
    </div>
    @if (isOrganizador)
    {
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-eventx-primary btn-lg">
                <i class="fas fa-plus"></i> Criar Novo Evento
            </a>
        </div>
    }
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="event-card fade-in-up">
                    <div class="event-card-header">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="mb-1">@Html.DisplayFor(modelItem => item.NomeEvento)</h5>
                                <small class="opacity-75">
                                    <i class="fas fa-calendar"></i> @item.DataEvento.ToString("dd/MM/yyyy")
                                </small>
                            </div>
                            <span class="badge bg-light text-dark">@Html.DisplayFor(modelItem => item.StatusEvento)</span>
                        </div>
                    </div>
                    <div class="event-card-body">
                        <p class="event-description mb-3">
                            @Html.DisplayFor(modelItem => item.DescricaoEvento)
                        </p>
                        <div class="row mb-3">
                            <div class="col-6">
                                <small class="text-muted">
                                    <i class="fas fa-tag"></i> @Html.DisplayFor(modelItem => item.TipoEvento)
                                </small>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">
                                    <i class="fas fa-map-marker-alt"></i> Local ID: @Html.DisplayFor(modelItem => item.LocalId)
                                </small>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-eye"></i> Ver
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                    <i class="fas fa-trash"></i> Excluir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="eventx-empty-state">
        <div class="eventx-empty-state-icon">
            <i class="fas fa-calendar-plus"></i>
        </div>
        <h3>Nenhum evento encontrado</h3>
        @if (isOrganizador)
        {
            <p>Comece criando seu primeiro evento e gerencie tudo em um só lugar!</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="fas fa-plus"></i> Criar Primeiro Evento
            </a>
        }
        else
        {
            <p>Nenhum evento disponível no momento.</p>
        }
    </div>
}
