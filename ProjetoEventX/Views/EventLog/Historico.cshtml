@model IEnumerable<ProjetoEventX.Models.EventLog>
@{
    var evento = ViewBag.Evento as ProjetoEventX.Models.Evento;
    ViewData["Title"] = $"Histórico - {evento?.NomeEvento}";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="fas fa-clock-rotate-left"></i> Histórico de Atividades</h2>
            <p class="text-muted mb-0">
                <i class="fas fa-calendar-alt"></i> @evento?.NomeEvento
                &nbsp;—&nbsp; @Model.Count() atividade(s) registrada(s)
            </p>
        </div>
        <a asp-controller="Eventos" asp-action="Details" asp-route-id="@evento?.Id" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Voltar ao Evento
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
            <p class="text-muted">Nenhuma atividade registrada para este evento ainda.</p>
        </div>
    }
    else
    {
        <!-- Filtros -->
        <div class="card mb-4">
            <div class="card-body py-2">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span class="fw-bold me-2"><i class="fas fa-filter"></i> Filtrar:</span>
                    <button class="btn btn-sm btn-outline-secondary active filter-btn" data-filter="all">Todos</button>
                    <button class="btn btn-sm btn-outline-primary filter-btn" data-filter="SolicitacaoOrcamento">Orçamentos</button>
                    <button class="btn btn-sm btn-outline-info filter-btn" data-filter="MensagemChat">Chat</button>
                    <button class="btn btn-sm btn-outline-success filter-btn" data-filter="PropostaAceita">Aceitas</button>
                    <button class="btn btn-sm btn-outline-danger filter-btn" data-filter="PropostaRecusada">Recusadas</button>
                    <button class="btn btn-sm btn-outline-warning filter-btn" data-filter="PedidoCriado">Pedidos</button>
                    <button class="btn btn-sm btn-outline-success filter-btn" data-filter="PagamentoConfirmado">Pagamentos</button>
                    <button class="btn btn-sm btn-outline-secondary filter-btn" data-filter="ConviteEnviado">Convites</button>
                    <button class="btn btn-sm btn-outline-primary filter-btn" data-filter="ConfirmacaoPresenca">Presenças</button>
                </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="timeline-container">
            @{
                string? lastDate = null;
            }
            @foreach (var log in Model)
            {
                var currentDate = log.CreatedAt.ToString("dd/MM/yyyy");
                if (currentDate != lastDate)
                {
                    lastDate = currentDate;
                    <div class="timeline-date-separator">
                        <span class="badge bg-dark px-3 py-2">
                            <i class="fas fa-calendar-day"></i> @log.CreatedAt.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))
                        </span>
                    </div>
                }

                var (icon, colorClass) = log.ActionType switch
                {
                    "SolicitacaoOrcamento" => ("fas fa-file-invoice-dollar", "primary"),
                    "RespostaFornecedor" => ("fas fa-reply", "info"),
                    "MensagemChat" => ("fas fa-comment-dots", "info"),
                    "PropostaAceita" => ("fas fa-check-circle", "success"),
                    "PropostaRecusada" => ("fas fa-times-circle", "danger"),
                    "PedidoCriado" => ("fas fa-shopping-cart", "warning"),
                    "PagamentoConfirmado" => ("fas fa-credit-card", "success"),
                    "DespesaRegistrada" => ("fas fa-receipt", "secondary"),
                    "ConviteEnviado" => ("fas fa-envelope", "secondary"),
                    "ConfirmacaoPresenca" => ("fas fa-user-check", "primary"),
                    _ => ("fas fa-circle-info", "secondary")
                };

                var actionLabel = log.ActionType switch
                {
                    "SolicitacaoOrcamento" => "Solicitação de Orçamento",
                    "RespostaFornecedor" => "Resposta de Fornecedor",
                    "MensagemChat" => "Mensagem no Chat",
                    "PropostaAceita" => "Proposta Aceita",
                    "PropostaRecusada" => "Proposta Recusada",
                    "PedidoCriado" => "Pedido Criado",
                    "PagamentoConfirmado" => "Pagamento Confirmado",
                    "DespesaRegistrada" => "Despesa Registrada",
                    "ConviteEnviado" => "Convite Enviado",
                    "ConfirmacaoPresenca" => "Confirmação de Presença",
                    _ => log.ActionType
                };

                <div class="timeline-item" data-action="@log.ActionType">
                    <div class="d-flex align-items-start gap-3 p-3 border-bottom">
                        <div class="timeline-icon bg-@colorClass bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" 
                             style="width: 44px; height: 44px; min-width: 44px;">
                            <i class="@icon text-@colorClass"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="badge bg-@colorClass bg-opacity-75">@actionLabel</span>
                                <small class="text-muted">
                                    <i class="fas fa-clock"></i> @log.CreatedAt.ToString("HH:mm")
                                </small>
                            </div>
                            <p class="mb-0 text-secondary">@log.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            const filter = this.dataset.filter;
            document.querySelectorAll('.timeline-item').forEach(item => {
                item.style.display = (filter === 'all' || item.dataset.action === filter) ? '' : 'none';
            });
            // Mostrar/ocultar separadores de data conforme itens visíveis
            document.querySelectorAll('.timeline-date-separator').forEach(sep => {
                let next = sep.nextElementSibling;
                let hasVisible = false;
                while (next && !next.classList.contains('timeline-date-separator')) {
                    if (next.classList.contains('timeline-item') && next.style.display !== 'none') {
                        hasVisible = true;
                        break;
                    }
                    next = next.nextElementSibling;
                }
                sep.style.display = hasVisible ? '' : 'none';
            });
        });
    });
</script>
}

<style>
    .timeline-date-separator {
        text-align: center;
        margin: 1.5rem 0 1rem;
    }
    .timeline-container .timeline-item:first-of-type .border-bottom {
        border-top: 1px solid #dee2e6 !important;
        border-top-left-radius: 0.5rem;
        border-top-right-radius: 0.5rem;
    }
    .timeline-container .timeline-item:last-of-type .border-bottom {
        border-bottom: none !important;
        border-bottom-left-radius: 0.5rem;
        border-bottom-right-radius: 0.5rem;
    }
    .timeline-item .border-bottom {
        background: #fff;
        transition: background 0.15s;
    }
    .timeline-item .border-bottom:hover {
        background: #f8f9fa;
    }
</style>
