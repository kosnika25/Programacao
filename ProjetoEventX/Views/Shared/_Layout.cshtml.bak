<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventX</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoEventX.styles.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    @await RenderSectionAsync("Styles", required: false)
</head>

@inject Microsoft.AspNetCore.Identity.UserManager<ProjetoEventX.Models.ApplicationUser> UserManager

@{
    string tipoUsuario = "";
    if (User.Identity?.IsAuthenticated == true)
    {
        var appUser = await UserManager.GetUserAsync(User);
        tipoUsuario = appUser?.TipoUsuario ?? "";
    }
}

<body>
    <!-- Mostrar mensagens de alerta globais -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show m-3" role="alert">
            <i class="fas fa-info-circle"></i> @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Header -->
    <header class="eventx-header">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="eventx-logo">
                        <img src="~/Images/Logo_com_nome.png" alt="Logo EventX" class="mb-4" style="width:180px;">
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Eventos" asp-action="Index">
                                <i class="fas fa-calendar-alt"></i> Eventos
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (tipoUsuario == "Organizador")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Organizador" asp-action="Dashboard">
                                        <i class="fas fa-gauge"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="TemplateConvite" asp-action="Index">
                                        <i class="fas fa-envelope-open-text"></i> Templates
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Pedido" asp-action="Index">
                                        <i class="fas fa-shopping-cart"></i> Pedidos
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Orcamento" asp-action="Index">
                                        <i class="fas fa-file-invoice-dollar"></i> Orçamentos
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="IA" asp-action="Index">
                                        <i class="fas fa-robot"></i> Assistente IA
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AvaliacaoFornecedor" asp-action="MeusEventosParaAvaliar">
                                        <i class="fas fa-star"></i> Avaliar
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Marketplace" asp-action="Index">
                                        <i class="fas fa-store"></i> Marketplace
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="RankingFornecedor" asp-action="Index">
                                        <i class="fas fa-ranking-star"></i> Ranking
                                    </a>
                                </li>
                            }
                            else if (tipoUsuario == "Fornecedor")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Fornecedor" asp-action="Dashboard">
                                        <i class="fas fa-gauge"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Marketplace" asp-action="SolicitacoesRecebidas">
                                        <i class="fas fa-inbox"></i> Solicitações
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Orcamento" asp-action="Index">
                                        <i class="fas fa-file-invoice-dollar"></i> Orçamentos
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Fornecedor" asp-action="Performance">
                                        <i class="fas fa-chart-line"></i> Performance
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="RankingFornecedor" asp-action="Index">
                                        <i class="fas fa-ranking-star"></i> Ranking
                                    </a>
                                </li>
                            }
                            <!-- Sino de Notificações -->
                            <li class="nav-item dropdown" id="notificationBell">
                                <a class="nav-link position-relative" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" id="notificationDropdownToggle">
                                    <i class="fas fa-bell fa-lg"></i>
                                    <span class="badge bg-danger rounded-pill position-absolute top-0 start-100 translate-middle d-none" id="notificationBadge" style="font-size: 0.65rem;">0</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" id="notificationDropdown" style="width: 360px; max-height: 420px; overflow-y: auto;">
                                    <li class="dropdown-header d-flex justify-content-between align-items-center px-3">
                                        <strong><i class="fas fa-bell me-1"></i> Notificações</strong>
                                        <button class="btn btn-sm btn-link text-decoration-none p-0" id="markAllReadBtn" title="Marcar todas como lidas">
                                            <i class="fas fa-check-double"></i> Marcar lidas
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <div id="notificationList">
                                        <li class="text-center text-muted py-3"><small>Nenhuma notificação</small></li>
                                    </div>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li class="text-center py-2">
                                        <a href="/Notificacao" class="text-decoration-none"><small>Ver todas as notificações</small></a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu">
                                    @if (tipoUsuario == "Organizador")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Organizador" asp-action="Profile"><i class="fas fa-user"></i> Perfil</a></li>
                                        <li><a class="dropdown-item" asp-controller="Eventos" asp-action="Index"><i class="fas fa-calendar"></i> Meus Eventos</a></li>
                                    }
                                    else if (tipoUsuario == "Fornecedor")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Fornecedor" asp-action="Dashboard"><i class="fas fa-store"></i> Minha Loja</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt"></i> Sair
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-sign-in-alt"></i> Entrar
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="LoginOrganizador"><i class="fas fa-user-tie"></i> Organizador</a></li>
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="LoginFornecedor"><i class="fas fa-store"></i> Fornecedor</a></li>
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="LoginConvidado"><i class="fas fa-users"></i> Convidado</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-plus"></i> Cadastrar
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="RegistroOrganizador"><i class="fas fa-user-tie"></i> Organizador</a></li>
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="RegistroFornecedor"><i class="fas fa-store"></i> Fornecedor</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main -->
    @RenderBody()

    <!-- Footer -->
    <footer class="eventx-footer border-top text-muted mt-5 py-3">
        <div class="container text-center">
            <div class="footer-logo mb-2">
                <img src="~/Images/Logo_com_nome.png" alt="Logo EventX" class="mb-4" style="width:180px;">
            </div>
            <p>&copy; 2025 - EventX - Onde organizar e amar compartilhar o seu evento é só o começo.</p>
            <p class="small">
                <span class="text-muted">Versão 2.0 com IA</span> | 
                <a href="#" class="text-muted">Suporte</a> | 
                <a href="#" class="text-muted">Privacidade</a>
            </p>
        </div>
    </footer>

    <!-- Scripts principais -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/formatacao.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
    
    <!-- Auto-dismiss alerts -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-dismiss success alerts after 5 seconds
            setTimeout(function() {
                const alerts = document.querySelectorAll('.alert-success');
                alerts.forEach(alert => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });
    </script>

    @if (User.Identity?.IsAuthenticated == true)
    {
    <script>
        (function() {
            const typeIcons = {
                'RespostaOrcamento': 'fas fa-file-invoice-dollar text-primary',
                'NovaMensagem': 'fas fa-comment-dots text-info',
                'PropostaAceita': 'fas fa-check-circle text-success',
                'PropostaRecusada': 'fas fa-times-circle text-danger',
                'NovoPedido': 'fas fa-shopping-cart text-warning',
                'PagamentoConfirmado': 'fas fa-credit-card text-success',
                'ConfirmacaoPresenca': 'fas fa-user-check text-primary'
            };

            function getIcon(type) {
                return typeIcons[type] || 'fas fa-bell text-secondary';
            }

            function loadNotifications() {
                $.getJSON('/Notificacao/GetUnread', function(data) {
                    var badge = $('#notificationBadge');
                    var list = $('#notificationList');

                    // Atualizar badge
                    if (data.unreadCount > 0) {
                        badge.text(data.unreadCount > 99 ? '99+' : data.unreadCount);
                        badge.removeClass('d-none');
                    } else {
                        badge.addClass('d-none');
                    }

                    // Atualizar lista
                    if (data.notifications.length === 0) {
                        list.html('<li class="text-center text-muted py-3"><small>Nenhuma notificação</small></li>');
                        return;
                    }

                    var html = '';
                    data.notifications.forEach(function(n) {
                        var bgClass = n.isRead ? '' : 'bg-light';
                        var linkHref = n.link || '/Notificacao';
                        html += '<li>' +
                            '<a class="dropdown-item py-2 px-3 ' + bgClass + ' notification-item" href="javascript:void(0)" ' +
                               'data-id="' + n.id + '" data-link="' + linkHref + '">' +
                            '<div class="d-flex align-items-start">' +
                                '<i class="' + getIcon(n.type) + ' me-2 mt-1"></i>' +
                                '<div class="flex-grow-1" style="min-width:0">' +
                                    '<div class="fw-semibold text-truncate" style="font-size:0.85rem">' + escapeHtml(n.title) + '</div>' +
                                    '<div class="text-muted text-truncate" style="font-size:0.78rem">' + escapeHtml(n.message) + '</div>' +
                                    '<small class="text-muted">' + n.timeAgo + '</small>' +
                                '</div>' +
                                (!n.isRead ? '<span class="ms-2 mt-1"><i class="fas fa-circle text-primary" style="font-size:0.5rem"></i></span>' : '') +
                            '</div>' +
                            '</a>' +
                        '</li>';
                    });
                    list.html(html);
                });
            }

            function escapeHtml(text) {
                var div = document.createElement('div');
                div.appendChild(document.createTextNode(text));
                return div.innerHTML;
            }

            // Marcar como lida e navegar
            $(document).on('click', '.notification-item', function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                var link = $(this).data('link');
                $.post('/Notificacao/MarkAsRead/' + id, function() {
                    window.location.href = link;
                });
            });

            // Marcar todas como lidas
            $('#markAllReadBtn').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                $.post('/Notificacao/MarkAllAsRead', function() {
                    loadNotifications();
                });
            });

            // Carregar ao abrir dropdown
            $('#notificationDropdownToggle').on('click', function() {
                loadNotifications();
            });

            // Polling a cada 30 segundos (só o badge)
            setInterval(function() {
                $.getJSON('/Notificacao/UnreadCount', function(data) {
                    var badge = $('#notificationBadge');
                    if (data.count > 0) {
                        badge.text(data.count > 99 ? '99+' : data.count);
                        badge.removeClass('d-none');
                    } else {
                        badge.addClass('d-none');
                    }
                });
            }, 30000);

            // Carga inicial do badge
            $.getJSON('/Notificacao/UnreadCount', function(data) {
                var badge = $('#notificationBadge');
                if (data.count > 0) {
                    badge.text(data.count > 99 ? '99+' : data.count);
                    badge.removeClass('d-none');
                }
            });
        })();
    </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
