@model ProjetoEventX.Models.Fornecedor
@{
    ViewData["Title"] = "Avaliações do Fornecedor";
    var avaliacoes = Model.Avaliacoes?.OrderByDescending(a => a.DataAvaliacao).ToList() ?? new List<ProjetoEventX.Models.AvaliacaoFornecedor>();
    var totalAvaliacoes = avaliacoes.Count;
    var notaMedia = Model.AvaliacaoMedia;
}

<style>
    .avaliacoes-section {
        background: #f5f0eb;
        min-height: 80vh;
        padding: 2rem 0 3rem;
    }
    .avaliacoes-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        padding: 2rem;
        margin-bottom: 2rem;
    }
    .nota-media-box {
        text-align: center;
        margin-bottom: 2rem;
    }
    .nota-media {
        font-size: 3rem;
        font-weight: 800;
        color: #8B0000;
    }
    .estrelas {
        font-size: 1.5rem;
        color: #f59e0b;
        margin-bottom: 0.5rem;
    }
    .estrelas .empty { color: #ddd; }
    .avaliacoes-count {
        font-size: 1rem;
        color: #555;
        margin-bottom: 0.5rem;
    }
    .comentario-card {
        background: #faf8f5;
        border-radius: 14px;
        padding: 1.2rem;
        margin-bottom: 1rem;
    }
    .comentario-header {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 0.5rem;
    }
    .comentario-avatar {
        width: 40px;
        height: 40px;
        background: #8B0000;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 0.9rem;
    }
    .comentario-nome { font-weight: 600; color: #333; font-size: 0.95rem; }
    .comentario-data { font-size: 0.8rem; color: #999; }
    .comentario-estrelas { color: #f59e0b; font-size: 1rem; margin-bottom: 0.4rem; }
    .comentario-texto { font-size: 0.95rem; color: #666; }
    .comentario-evento {
        font-size: 0.8rem;
        color: #8B0000;
        margin-top: 0.4rem;
    }
</style>

<section class="avaliacoes-section">
    <div class="container">
        <div class="avaliacoes-card">
            <div class="nota-media-box">
                <div class="nota-media">@notaMedia.ToString("N1")</div>
                <div class="estrelas">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(notaMedia))
                        {
                            <i class="fas fa-star"></i>
                        }
                        else
                        {
                            <i class="fas fa-star empty"></i>
                        }
                    }
                </div>
                <div class="avaliacoes-count">
                    @totalAvaliacoes @(totalAvaliacoes == 1 ? "avaliação" : "avaliações")
                </div>
            </div>

            @if (avaliacoes.Any())
            {
                @foreach (var avaliacao in avaliacoes)
                {
                    var inicialNome = avaliacao.Organizador?.Pessoa?.Nome?.Substring(0, 1).ToUpper() ?? "?";
                    <div class="comentario-card">
                        <div class="comentario-header">
                            <div class="comentario-avatar">@inicialNome</div>
                            <div>
                                <div class="comentario-nome">@(avaliacao.Organizador?.Pessoa?.Nome ?? "Organizador")</div>
                                <div class="comentario-data">@avaliacao.DataAvaliacao.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                        <div class="comentario-estrelas">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star" style="color: @(i <= avaliacao.Nota ? "#f59e0b" : "#ddd")"></i>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(avaliacao.Comentario))
                        {
                            <div class="comentario-texto">@avaliacao.Comentario</div>
                        }
                        @if (avaliacao.Evento != null)
                        {
                            <div class="comentario-evento">
                                <i class="fas fa-calendar-alt"></i> @avaliacao.Evento.NomeEvento
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-muted text-center py-3"><i class="fas fa-star"></i> Nenhuma avaliação ainda.</p>
            }
        </div>
    </div>
</section>
