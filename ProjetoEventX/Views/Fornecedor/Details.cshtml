@model ProjetoEventX.Models.Fornecedor
@{
    ViewData["Title"] = "Perfil do Fornecedor";
}

<div class="container py-4 animate-in">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg rounded-4 border-0 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <img src="@Model.FotoPerfilUrl" class="rounded-circle me-4" style="width:80px;height:80px;object-fit:cover;box-shadow:0 2px 8px rgba(0,0,0,0.12);" />
                        <div>
                            <h2 class="fw-bold mb-1">@Model.NomeNegocio</h2>
                            <div class="text-muted mb-1">@Model.Categoria &bull; @Model.Cidade, @Model.Regiao</div>
                            <div class="mb-2"><span class="badge bg-success">@Model.FaixaPreco</span></div>
                            <div class="mb-2">Contato: <strong>@Model.Email</strong> | <span class="text-muted">@Model.Telefone</span></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <h5 class="fw-bold">Descrição</h5>
                        <div class="text-muted">@Model.Descricao</div>
                    </div>
                    <div class="mb-3">
                        <h5 class="fw-bold">Serviços Oferecidos</h5>
                        <ul class="list-group list-group-flush">
                            @foreach(var servico in Model.ServicosOferecidos ?? new List<string>())
                            {
                                <li class="list-group-item bg-transparent">@servico</li>
                            }
                        </ul>
                    </div>
                    <div class="mb-3">
                        <h5 class="fw-bold">Galeria</h5>
                        <div class="row g-3">
                            @foreach(var foto in Model.Galeria ?? new List<string>())
                            {
                                <div class="col-md-3">
                                    <img src="@foto" class="img-fluid rounded shadow-sm" style="height:120px;object-fit:cover;" />
                                </div>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <h5 class="fw-bold">Disponibilidade</h5>
                        <div class="text-muted">@Model.Disponibilidade</div>
                    </div>
                    <div class="mb-3">
                        <h5 class="fw-bold">Avaliações</h5>
                        <div class="d-flex align-items-center mb-2">
                            <span class="me-2 fw-bold">@Model.AvaliacaoMedia.ToString("N1")</span>
                            <span class="text-warning"><i class="fas fa-star"></i></span>
                            <span class="ms-2 text-muted small">(@Model.TotalAvaliacoes) avaliações</span>
                        </div>
                        <!-- Futuro: lista de avaliações detalhadas -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
