@model IEnumerable<ProjetoEventX.Models.Produto>
@{
    ViewData["Title"] = "EventX - Catálogo de Produtos";
    var rankings = ViewBag.Rankings as Dictionary<int, ProjetoEventX.Models.FornecedorRanking> ?? new();
}

<style>
    .catalogo-section {
        background: var(--eventx-secondary, #f5f0eb);
        min-height: 80vh;
        padding: 3rem 0;
    }

    .catalogo-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .catalogo-header h2 {
        color: var(--eventx-primary, #8B0000);
        font-weight: 700;
        font-size: 2rem;
    }

    .catalogo-header p {
        color: #6c757d;
        font-size: 1.1rem;
    }

    .produto-card {
        text-align: center;
        padding: 2rem 1.5rem;
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        height: 100%;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .produto-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.15);
        color: inherit;
        text-decoration: none;
    }

    .produto-icon {
        width: 70px;
        height: 70px;
        background: var(--eventx-primary, #8B0000);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.2rem;
        color: #fff;
        font-size: 1.8rem;
    }

    .produto-card h5 {
        color: var(--eventx-primary, #8B0000);
        font-weight: 600;
        margin-bottom: 0.8rem;
        font-size: 1.15rem;
    }

    .produto-card .produto-descricao {
        color: #6c757d;
        font-size: 0.95rem;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .produto-preco {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--eventx-primary, #8B0000);
        margin-bottom: 0.5rem;
    }

    .produto-fornecedor {
        font-size: 0.85rem;
        color: #999;
    }

    .produto-fornecedor i {
        margin-right: 4px;
    }

    .produto-tipo-badge {
        display: inline-block;
        background: var(--eventx-primary, #8B0000);
        color: #fff;
        padding: 3px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 0.8rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }

    .empty-state i {
        font-size: 4rem;
        color: #ccc;
        margin-bottom: 1.5rem;
    }

    .empty-state h4 {
        color: #999;
        font-weight: 600;
    }

    .empty-state p {
        color: #aaa;
    }

    .ver-detalhes-btn {
        display: inline-block;
        margin-top: 0.8rem;
        padding: 6px 20px;
        background: var(--eventx-primary, #8B0000);
        color: #fff;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: background 0.3s;
    }

    .produto-card:hover .ver-detalhes-btn {
        background: var(--eventx-primary-dark, #654321);
    }

    .badge-top-forn {
        display: inline-flex; align-items: center; gap: 4px;
        background: linear-gradient(135deg, #f9a825, #ff8f00);
        color: #fff; padding: 2px 10px; border-radius: 12px;
        font-size: 0.7rem; font-weight: 600;
    }
    .fornecedor-metrics {
        display: flex; justify-content: center; gap: 0.7rem;
        font-size: 0.75rem; color: #888; margin-top: 4px;
    }
</style>

<section class="catalogo-section">
    <div class="container">
        <div class="catalogo-header">
            <h2><i class="fas fa-store"></i> Catálogo de Produtos</h2>
            <p>Explore os produtos e serviços oferecidos pelos nossos fornecedores</p>
        </div>

        @if (Model.Any())
        {
            <div class="row">
                @foreach (var produto in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <a asp-action="DetalhesProduto" asp-route-id="@produto.Id" class="produto-card">
                            <div class="produto-icon">
                                <i class="fas fa-box"></i>
                            </div>
                            <span class="produto-tipo-badge">@produto.Tipo</span>
                            <h5>@produto.Nome</h5>
                            <p class="produto-descricao">@produto.Descricao</p>
                            <p class="produto-preco">R$ @produto.Preco.ToString("N2")</p>
                            <p class="produto-fornecedor">
                                <i class="fas fa-store"></i> @produto.Fornecedor?.Pessoa?.Nome
                                @if (produto.Fornecedor != null && produto.Fornecedor.AvaliacaoMedia > 0)
                                {
                                    <span style="color:#f59e0b; margin-left:0.5rem;">
                                        <i class="fas fa-star"></i> @produto.Fornecedor.AvaliacaoMedia.ToString("N1")
                                    </span>
                                }
                            </p>
                            @if (produto.Fornecedor != null && rankings.TryGetValue(produto.Fornecedor.Id, out var rank))
                            {
                                @if (rank.IsTopFornecedor)
                                {
                                    <span class="badge-top-forn"><i class="fas fa-crown"></i> Top Fornecedor</span>
                                }
                                <div class="fornecedor-metrics">
                                    <span><i class="fas fa-calendar-check"></i> @rank.EventosAtendidos eventos</span>
                                    <span><i class="fas fa-clock"></i> @(rank.TempoMedioRespostaHoras < 1 ? $"{(int)(rank.TempoMedioRespostaHoras * 60)}min" : rank.TempoMedioRespostaHoras < 24 ? $"{rank.TempoMedioRespostaHoras:N0}h" : $"{(rank.TempoMedioRespostaHoras / 24):N0}d") resp.</span>
                                </div>
                            }
                            <span class="ver-detalhes-btn">
                                <i class="fas fa-eye"></i> Ver Detalhes
                            </span>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-box-open d-block"></i>
                <h4>Nenhum produto disponível</h4>
                <p>Os fornecedores ainda não cadastraram produtos.</p>
            </div>
        }
    </div>
</section>
