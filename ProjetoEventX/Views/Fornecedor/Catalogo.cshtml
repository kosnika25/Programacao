@model IEnumerable<ProjetoEventX.Models.ServicoFornecedorViewModel>
@{
    ViewData["Title"] = "Gerenciar Serviços";
    var fornecedorId = ViewBag.FornecedorId;
}

<div class="container py-4 animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-briefcase text-primary me-2"></i> Meus Serviços</h2>
            <div class="text-muted">Gerencie e organize seu catálogo de serviços.</div>
        </div>
        <a href="@Url.Action("AdicionarServico", new { fornecedorId = fornecedorId })" class="btn btn-primary btn-lg rounded-pill shadow-sm">
            <i class="fas fa-plus me-2"></i> Adicionar Serviço
        </a>
    </div>
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var servico in Model)
            {
                var statusBadge = servico.Ativo ? "badge bg-success" : "badge bg-secondary";
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg rounded-4 border-0 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="servico-icon bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px;font-size:1.5rem;">
                                    <i class="fas fa-briefcase"></i>
                                </div>
                                <h5 class="fw-bold mb-0">@servico.Nome</h5>
                                <span class="ms-auto @statusBadge">@(servico.Ativo ? "Ativo" : "Inativo")</span>
                            </div>
                            <div class="mb-2 text-muted">@servico.DescricaoCurta</div>
                            <div class="mb-2"><span class="badge bg-info text-dark">@servico.FaixaPreco</span></div>
                            <div class="d-flex gap-2 mt-3">
                                <a href="@Url.Action("EditarServico", new { id = servico.Id })" class="btn btn-sm btn-outline-info rounded-pill"><i class="fas fa-edit"></i> Editar</a>
                                <form asp-action="RemoverServico" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@servico.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Deseja remover este serviço?')"><i class="fas fa-trash-alt"></i> Remover</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center py-5">
            <i class="fas fa-briefcase fa-2x mb-2 text-secondary"></i>
            <h4 class="fw-bold mb-2">Nenhum serviço cadastrado</h4>
            <p class="text-muted">Adicione serviços para aparecer no seu catálogo.</p>
        </div>
    }
</div>
