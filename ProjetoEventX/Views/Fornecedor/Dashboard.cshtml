@model ProjetoEventX.Models.Fornecedor
@{
    ViewData["Title"] = "Dashboard - Fornecedor";
}

<div class="dashboard-main-grid">
    <div class="dashboard-main-area">
        <div class="dashboard-welcome-card mb-4">
            <div class="dashboard-welcome-avatar">
                <i class="fas fa-store"></i>
            </div>
            <div>
                <div class="dashboard-welcome-title">Olá, @(Model.Pessoa?.Nome ?? Model.UserName)!</div>
                <div class="dashboard-welcome-desc">Gerencie sua loja, produtos e pedidos</div>
            </div>
        </div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show saas-alert mb-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="dashboard-metrics-grid mb-4">
    <div class="dashboard-metric-card dashboard-metric-eventos">
        <div class="dashboard-metric-icon dashboard-metric-eventos"><i class="fas fa-box"></i></div>
        <div class="dashboard-metric-info">
            <div class="dashboard-metric-label">Produtos</div>
            <div class="dashboard-metric-value">@ViewBag.TotalProdutos</div>
        </div>
    </div>
    <div class="dashboard-metric-card dashboard-metric-convidados">
        <div class="dashboard-metric-icon dashboard-metric-convidados"><i class="fas fa-shopping-cart"></i></div>
        <div class="dashboard-metric-info">
            <div class="dashboard-metric-label">Pedidos</div>
            <div class="dashboard-metric-value">@ViewBag.TotalPedidos</div>
            <div class="dashboard-metric-change"><i class="fas fa-clock"></i> @ViewBag.PedidosPendentes pendentes</div>
        </div>
    </div>
    <div class="dashboard-metric-card dashboard-metric-despesas">
        <div class="dashboard-metric-icon dashboard-metric-despesas"><i class="fas fa-dollar-sign"></i></div>
        <div class="dashboard-metric-info">
            <div class="dashboard-metric-label">Receita</div>
            <div class="dashboard-metric-value">R$ @(((decimal)ViewBag.ReceitaTotal).ToString("N0"))</div>
        </div>
    </div>
    <div class="dashboard-metric-card dashboard-metric-concluidos">
        <div class="dashboard-metric-icon dashboard-metric-concluidos"><i class="fas fa-star"></i></div>
        <div class="dashboard-metric-info">
            <div class="dashboard-metric-label">Avaliação</div>
            <div class="dashboard-metric-value">@(Model.AvaliacaoMedia.ToString("N1"))</div>
            <div class="dashboard-metric-change">@ViewBag.TotalAvaliacoes avaliações</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column -->
    <div class="col-lg-8">
        <!-- Store Profile -->
        <div class="dashboard-charts-grid">
            <div class="dashboard-profile-card mb-4">
                <div class="dashboard-chart-title"><i class="fas fa-store"></i>Informações da Loja
                    <button class="btn btn-saas-outline btn-sm float-end" data-bs-toggle="modal" data-bs-target="#editPerfilModal">
                        <i class="fas fa-pen me-1"></i>Editar
                    </button>
                </div>
                <div>
                    @{
                        var perfilItems = new[] {
                            ("fa-store", "Nome", Model.Pessoa?.Nome ?? "Não informado"),
                            ("fa-id-card", "CNPJ", Model.Cnpj ?? "Não informado"),
                            ("fa-phone", "Telefone", Model.PhoneNumber ?? Model.Pessoa?.Telefone ?? "Não informado"),
                            ("fa-envelope", "Email", Model.Email ?? "Não informado"),
                            ("fa-map-marker-alt", "Local", $"{Model.Cidade ?? ""}/{Model.UF ?? ""}"),
                            ("fa-concierge-bell", "Serviço", Model.TipoServico ?? "Não informado"),
                            ("fa-calendar-check", "Desde", Model.DataCadastro.ToString("dd/MM/yyyy"))
                        };
                    }
                    @foreach (var item in perfilItems)
                    {
                        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.55rem 0; border-bottom: 1px solid var(--ex-border-light);">
                            <div style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: var(--ex-primary-bg); color: var(--ex-primary); border-radius: 8px; font-size: 0.8rem; flex-shrink: 0;">
                                <i class="fas @item.Item1"></i>
                            </div>
                            <div>
                                <div style="font-size: 0.7rem; color: var(--ex-text-muted); line-height: 1;">@item.Item2</div>
                                <div style="font-weight: 600; color: var(--ex-text); font-size: 0.88rem;">@item.Item3</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="dashboard-events-card mb-4">
                <div class="dashboard-events-header">
                    <span><i class="fas fa-box-open"></i>Meus Produtos</span>
                    <button class="btn btn-saas-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addProductModal">
                        <i class="fas fa-plus me-1"></i>Novo Produto
                    </button>
                </div>
                @if (Model.Produtos != null && Model.Produtos.Any())
                {
                    <div class="dashboard-events-list">
                    @foreach (var produto in Model.Produtos)
                    {
                        <div class="dashboard-event-item">
                            <div class="dashboard-event-date">
                                <i class="fas fa-box"></i>
                            </div>
                            <div class="dashboard-event-info">
                                <div class="dashboard-event-title">@produto.Nome</div>
                                <div class="dashboard-event-meta">@produto.Tipo · @produto.Descricao</div>
                            </div>
                            <div style="font-weight: 700; color: var(--ex-primary); font-size: 0.95rem; margin: 0 0.75rem; white-space: nowrap;">R$ @produto.Preco.ToString("N2")</div>
                            <div style="display: flex; gap: 4px; flex-shrink: 0;">
                                <button style="width: 30px; height: 30px; border-radius: 8px; border: none; background: var(--ex-info-bg); color: var(--ex-info); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; cursor: pointer;" title="Editar" data-bs-toggle="modal" data-bs-target="#editModal-@produto.Id.ToString().Replace("-","")">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button style="width: 30px; height: 30px; border-radius: 8px; border: none; background: var(--ex-danger-bg); color: var(--ex-danger); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; cursor: pointer;" title="Excluir" data-bs-toggle="modal" data-bs-target="#deleteModal-@produto.Id.ToString().Replace("-","")">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                    </div>
                }
                else
                {
                    <div class="dashboard-events-empty">
                        <i class="fas fa-box-open d-block"></i>
                        <div>Nenhum produto cadastrado</div>
                        <button class="btn btn-saas-primary btn-sm mt-2" data-bs-toggle="modal" data-bs-target="#addProductModal">
                            <i class="fas fa-plus me-1"></i>Cadastrar Produto
                        </button>
                    </div>
                }
            </div>
            </div>
            <div class="dashboard-side-area">
                <div class="dashboard-quick-actions-card mb-4">
                    <div class="dashboard-quick-actions-header"><i class="fas fa-bolt"></i>Ações Rápidas</div>
                    <div class="dashboard-quick-actions-list">
                        <div class="dashboard-quick-action" data-bs-toggle="modal" data-bs-target="#addProductModal">
                            <i class="fas fa-plus-circle"></i><span>Novo Produto</span>
                        </div>
                        <a asp-controller="Pedido" asp-action="Index" class="dashboard-quick-action">
                            <i class="fas fa-shopping-bag"></i><span>Pedidos</span>
                        </a>
                        <a asp-controller="Fornecedor" asp-action="Performance" class="dashboard-quick-action">
                            <i class="fas fa-chart-line"></i><span>Performance</span>
                        </a>
                        <a asp-controller="RankingFornecedor" asp-action="Index" class="dashboard-quick-action">
                            <i class="fas fa-trophy"></i><span>Ranking</span>
                        </a>
                    </div>
                </div>
                <div class="dashboard-events-card mb-4">
                    <div class="dashboard-events-header"><i class="fas fa-shopping-bag"></i>Pedidos Recentes</div>
                    @{
                        var pedidosRecentes = ViewBag.PedidosRecentes as List<ProjetoEventX.Models.Pedido>;
                    }
                    @if (pedidosRecentes != null && pedidosRecentes.Any())
                    {
                        <div class="dashboard-events-list">
                        @foreach (var pedido in pedidosRecentes)
                        {
                            <div class="dashboard-event-item">
                                <div class="dashboard-event-date">
                                    <i class="fas fa-receipt"></i>
                                </div>
                                <div class="dashboard-event-info">
                                    <div class="dashboard-event-title">@(pedido.Produto?.Nome ?? "Produto") — @(pedido.Evento?.NomeEvento ?? "")</div>
                                    <div class="dashboard-event-meta">
                                        @pedido.DataPedido.ToString("dd/MM/yyyy") ·
                                        <span class="badge-saas @(pedido.StatusPedido == "Pendente" ? "badge-warning" : pedido.StatusPedido == "Pago" ? "badge-info" : pedido.StatusPedido == "Entregue" ? "badge-success" : "badge-primary")" style="font-size: 0.65rem;">@pedido.StatusPedido</span>
                                    </div>
                                </div>
                                <div style="font-weight: 700; color: var(--ex-primary); font-size: 0.85rem; white-space: nowrap; margin-left: 0.5rem;">R$ @pedido.PrecoTotal.ToString("N2")</div>
                            </div>
                        }
                        </div>
                    }
                    else
                    {
                        <div class="dashboard-events-empty">
                            <i class="fas fa-inbox d-block" style="font-size: 2rem;"></i>
                            <div style="font-size: 0.85rem; margin: 0;">Nenhum pedido recebido ainda.</div>
                        </div>
                    }
                </div>
                <div class="dashboard-notifications-card">
                    <div class="dashboard-notifications-header"><i class="fas fa-star"></i>Avaliações Recentes</div>
                    @{
                        var avaliacoesRecentes = ViewBag.AvaliacoesRecentes as List<ProjetoEventX.Models.AvaliacaoFornecedor>;
                    }
                    @if (avaliacoesRecentes != null && avaliacoesRecentes.Any())
                    {
                        <div class="dashboard-notifications-list">
                        @foreach (var avaliacao in avaliacoesRecentes)
                        {
                            <div class="dashboard-notification-item">
                                <div class="dashboard-notification-icon"><i class="fas fa-star"></i></div>
                                <div class="dashboard-notification-info">
                                    <div class="dashboard-notification-message">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="fa@(i <= avaliacao.Nota ? "s" : "r") fa-star" style="color: @(i <= avaliacao.Nota ? "#F59E0B" : "#E5E7EB"); font-size: 0.75rem;"></i>
                                        }
                                        <span style="font-size: 0.72rem; color: var(--ex-text-muted);">@avaliacao.Organizador?.Pessoa?.Nome</span>
                                    </div>
                                    <div class="dashboard-notification-date">@(avaliacao.Comentario ?? "Sem comentário")</div>
                                </div>
                            </div>
                        }
                        <div class="dashboard-notifications-empty mt-2">
                            <a asp-controller="AvaliacaoFornecedor" asp-action="Avaliacoes" asp-route-fornecedorId="@Model.Id" style="color: var(--ex-primary); font-weight: 600; font-size: 0.85rem; text-decoration: none;">
                                Ver todas <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                        </div>
                    }
                    else
                    {
                        <div class="dashboard-notifications-empty">
                            <i class="fas fa-star d-block" style="font-size: 2rem;"></i>
                            <div style="font-size: 0.85rem; margin: 0;">Nenhuma avaliação recebida.</div>
                        </div>
                    }
                </div>
            </div>
        </div>
            else
            {
                <div class="empty-state" style="padding: 1.5rem;">
                    <i class="fas fa-star d-block" style="font-size: 2rem;"></i>
                    <p style="font-size: 0.85rem; margin: 0;">Nenhuma avaliação recebida.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Editar Perfil da Loja -->
<div class="modal fade" id="editPerfilModal" tabindex="-1" aria-labelledby="editPerfilModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius: var(--radius-lg); overflow: hidden;">
            <div class="modal-header" style="background: linear-gradient(135deg, var(--ex-primary), var(--ex-primary-light)); color: #fff; border: none;">
                <h5 class="modal-title" id="editPerfilModalLabel"><i class="fas fa-store me-2"></i>Editar Informações da Loja</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="Fornecedor" asp-action="EditarPerfil" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-store me-1 text-muted"></i> Nome da Loja</label>
                                <input type="text" class="form-control" name="NomeLoja" value="@(Model.Pessoa?.Nome)" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-id-card me-1 text-muted"></i> CNPJ</label>
                                <input type="text" class="form-control" name="Cnpj" value="@Model.Cnpj" required />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-phone me-1 text-muted"></i> Telefone</label>
                                <input type="text" class="form-control" name="Telefone" value="@(Model.PhoneNumber ?? Model.Pessoa?.Telefone)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-concierge-bell me-1 text-muted"></i> Tipo de Serviço</label>
                                @{
                                    var tiposServico = new[] { "Buffet", "Decoração", "Fotografia", "Música", "Locação", "Outros" };
                                }
                                <select class="form-control" name="TipoServico" required>
                                    @foreach (var tipo in tiposServico)
                                    {
                                        if (Model.TipoServico == tipo)
                                        {
                                            <option value="@tipo" selected>@tipo</option>
                                        }
                                        else
                                        {
                                            <option value="@tipo">@tipo</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-map-marker-alt me-1 text-muted"></i> Cidade</label>
                                <input type="text" class="form-control" name="Cidade" value="@Model.Cidade" required />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="mb-3">
                                <label class="form-label">UF</label>
                                <input type="text" class="form-control" name="UF" value="@Model.UF" maxlength="2" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label"><i class="fas fa-home me-1 text-muted"></i> Endereço</label>
                                <input type="text" class="form-control" name="Endereco" value="@(Model.Pessoa?.Endereco)" />
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-saas-primary"><i class="fas fa-save me-1"></i>Salvar Alterações</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Add Product Modal -->
<div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: var(--radius-lg); overflow: hidden;">
            <div class="modal-header" style="background: linear-gradient(135deg, var(--ex-primary), var(--ex-primary-light)); color: #fff; border: none;">
                <h5 class="modal-title" id="addProductModalLabel"><i class="fas fa-plus-circle me-2"></i>Adicionar Produto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="Fornecedor" asp-action="AddProduct" method="post">
                    <div class="mb-3">
                        <label for="productName" class="form-label">Nome do Produto</label>
                        <input type="text" class="form-control" id="productName" name="ProductName" required>
                    </div>
                    <div class="mb-3">
                        <label for="productDescription" class="form-label">Descrição</label>
                        <textarea class="form-control" id="productDescription" name="ProductDescription" rows="3" required></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label for="productPrice" class="form-label">Preço (R$)</label>
                                <input type="number" class="form-control" id="productPrice" name="ProductPrice" step="0.01" required>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label for="productType" class="form-label">Tipo</label>
                                <select class="form-control" id="productType" name="ProductType" required>
                                    <option value="Produto">Produto</option>
                                    <option value="Local">Local</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-saas-primary w-100"><i class="fas fa-plus me-1"></i>Adicionar Produto</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modais de Edição e Exclusão para cada produto -->
@if (Model.Produtos != null && Model.Produtos.Any())
{
    @foreach (var produto in Model.Produtos)
    {
        var modalEditId = "editModal-" + produto.Id.ToString().Replace("-","");
        var modalDeleteId = "deleteModal-" + produto.Id.ToString().Replace("-","");

        <div class="modal fade" id="@modalEditId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content" style="border-radius: var(--radius-lg); overflow: hidden;">
                    <div class="modal-header" style="background: linear-gradient(135deg, var(--ex-info), #60A5FA); color: #fff; border: none;">
                        <h5 class="modal-title"><i class="fas fa-pen me-2"></i>Editar Produto</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form asp-controller="Fornecedor" asp-action="EditarProduto" method="post">
                            <input type="hidden" name="produtoId" value="@produto.Id" />
                            <div class="mb-3">
                                <label class="form-label">Nome do Produto</label>
                                <input type="text" class="form-control" name="Nome" value="@produto.Nome" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Descrição</label>
                                <textarea class="form-control" name="Descricao" rows="3" required>@produto.Descricao</textarea>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Preço (R$)</label>
                                        <input type="number" class="form-control" name="Preco" step="0.01" value="@produto.Preco.ToString(System.Globalization.CultureInfo.InvariantCulture)" required />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <label class="form-label">Tipo</label>
                                        <select class="form-control" name="Tipo" required>
                                            @if (produto.Tipo == "Produto")
                                            {
                                                <option value="Produto" selected>Produto</option>
                                                <option value="Local">Local</option>
                                            }
                                            else
                                            {
                                                <option value="Produto">Produto</option>
                                                <option value="Local" selected>Local</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-saas-primary w-100"><i class="fas fa-save me-1"></i>Salvar Alterações</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="@modalDeleteId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-sm">
                <div class="modal-content" style="border-radius: var(--radius-lg); overflow: hidden;">
                    <div class="modal-header" style="background: linear-gradient(135deg, var(--ex-danger), #F87171); color: #fff; border: none;">
                        <h5 class="modal-title"><i class="fas fa-trash me-2"></i>Excluir Produto</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center p-4">
                        <i class="fas fa-exclamation-triangle" style="font-size: 2.5rem; color: var(--ex-warning); margin-bottom: 1rem;"></i>
                        <p style="font-weight: 600; color: var(--ex-text);">Tem certeza que deseja excluir</p>
                        <p style="font-size: 1.1rem; font-weight: 700; color: var(--ex-primary);">@produto.Nome</p>
                        <p style="font-size: 0.82rem; color: var(--ex-text-muted);">Esta ação não pode ser desfeita.</p>
                    </div>
                    <div class="modal-footer justify-content-center" style="border: none;">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <form asp-controller="Fornecedor" asp-action="ExcluirProduto" method="post" class="d-inline">
                            <input type="hidden" name="produtoId" value="@produto.Id" />
                            <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Excluir</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
