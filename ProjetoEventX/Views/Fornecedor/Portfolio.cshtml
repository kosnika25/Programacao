@model IEnumerable<ProjetoEventX.Models.FotoPortfolioViewModel>
@{
    ViewBag.Title = "Portfólio do Fornecedor";
    var fornecedorId = ViewBag.FornecedorId;
}

<div class="container py-4 animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-image text-primary me-2"></i> Portfólio Profissional</h2>
            <div class="text-muted">Valorize seu trabalho mostrando fotos dos serviços realizados.</div>
        </div>
        <a href="@Url.Action("AdicionarFoto", new { fornecedorId = fornecedorId })" class="btn btn-primary btn-lg rounded-pill shadow-sm">
            <i class="fas fa-plus me-2"></i> Adicionar Foto
        </a>
    </div>
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var foto in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card portfolio-card shadow-sm rounded-4 mb-3">
                        <div class="portfolio-img-box position-relative">
                            <img src="@foto.ImagemUrl" class="img-fluid rounded-top-4 portfolio-img" alt="Foto do portfólio" />
                            @if (foto.Capa)
                            {
                                <span class="badge bg-primary position-absolute top-0 start-0 m-2">Capa</span>
                            }
                        </div>
                        <div class="card-body p-2">
                            <div class="portfolio-legenda text-muted small">@foto.Legenda</div>
                            <div class="d-flex gap-2 mt-2">
                                <a href="@Url.Action("EditarFoto", new { id = foto.Id })" class="btn btn-sm btn-outline-info rounded-pill"><i class="fas fa-edit"></i> Editar</a>
                                <form asp-action="ExcluirFoto" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@foto.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Deseja excluir esta foto?')"><i class="fas fa-trash-alt"></i> Excluir</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center py-5">
            <i class="fas fa-image fa-2x mb-2 text-secondary"></i>
            <h4 class="fw-bold mb-2">Nenhuma foto no portfólio</h4>
            <p class="text-muted">Adicione fotos para valorizar seu trabalho.</p>
        </div>
    }
</div>
<style>
.portfolio-card {
    border-radius: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.portfolio-img-box {
    height: 180px;
    overflow: hidden;
    border-radius: 1.5rem 1.5rem 0 0;
    background: #f5f1ed;
}
.portfolio-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.portfolio-legenda {
    font-size: 0.92rem;
    color: #888;
}
</style>
