@model IEnumerable<ProjetoEventX.Models.MensagemChat>
@{
    ViewData["Title"] = "Chat do Evento";
    var eventoId = ViewBag.EventoId;
    var eventoNome = ViewBag.NomeEvento;
}

<div class="chat-modern animate-in">
    <!-- Header -->
    <div class="chat-modern-header">
        <div class="chat-avatar">
            <i class="fas fa-comments" style="font-size:1rem;"></i>
        </div>
        <div class="chat-info" style="flex:1;">
            <h5>@eventoNome</h5>
            <span>Chat do evento &middot; @Model.Count() mensagens</span>
        </div>
        <a asp-controller="Organizador" asp-action="Dashboard" class="btn btn-sm btn-eventx-outline">
            <i class="fas fa-arrow-left me-1"></i> Voltar
        </a>
    </div>

    <!-- Mensagens -->
    <div class="chat-modern-messages" id="chatMessages">
        @if (!Model.Any())
        {
            <div class="chat-empty-state">
                <i class="fas fa-comments"></i>
                <h5>Nenhuma mensagem ainda</h5>
                <p>Envie a primeira mensagem para iniciar a conversa sobre este evento.</p>
            </div>
        }
        else
        {
            @foreach (var msg in Model)
            {
                var isSent = msg.RemetenteId == (int)ViewBag.CurrentUserId;
                <div class="chat-bubble @(isSent ? "sent" : "received")">
                    @if (!isSent)
                    {
                        <div class="bubble-sender">@(msg.Remetente?.Nome ?? "Usuário")</div>
                    }
                    <div>@msg.Conteudo</div>
                    <div class="bubble-time">@msg.DataEnvio.ToString("dd/MM HH:mm")</div>
                </div>
            }
        }
    </div>

    <!-- Input -->
    <div class="chat-modern-input">
        <form id="chatForm" style="display:contents;">
            @Html.AntiForgeryToken()
            <input type="hidden" id="eventoId" value="@eventoId" />
            <input type="hidden" id="remetenteId" value="@ViewBag.CurrentUserId" />
            <input type="text" id="mensagemInput" placeholder="Digite sua mensagem..." autocomplete="off" />
            <button type="submit" class="btn-send" title="Enviar">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.start().then(() => {
            connection.invoke("JoinEventGroup", @eventoId);
        });

        connection.on("ReceiveMessage", (convidadoId, mensagem, nomeUsuario, dataEnvio) => {
            const chatMessages = document.getElementById("chatMessages");
            // Remove empty state if present
            const emptyState = chatMessages.querySelector('.chat-empty-state');
            if (emptyState) emptyState.remove();

            const isSent = convidadoId == "@ViewBag.CurrentUserId";
            const bubble = document.createElement("div");
            bubble.className = "chat-bubble " + (isSent ? "sent" : "received");

            let html = '';
            if (!isSent) {
                html += '<div class="bubble-sender">' + escapeHtml(nomeUsuario) + '</div>';
            }
            html += '<div>' + escapeHtml(mensagem) + '</div>';
            html += '<div class="bubble-time">' + new Date(dataEnvio).toLocaleString('pt-BR', {day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit'}) + '</div>';
            bubble.innerHTML = html;
            chatMessages.appendChild(bubble);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        });

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        document.getElementById("chatForm").addEventListener("submit", async (e) => {
            e.preventDefault();
            const mensagem = document.getElementById("mensagemInput").value;
            const eventoId = document.getElementById("eventoId").value;
            const remetenteId = document.getElementById("remetenteId").value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (mensagem.trim()) {
                await fetch('/Chat/EnviarMensagem', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'eventoId=' + eventoId + '&remetenteId=' + remetenteId + '&destinatarioId=' + remetenteId + '&conteudo=' + encodeURIComponent(mensagem) + '&__RequestVerificationToken=' + encodeURIComponent(token)
                });
                document.getElementById("mensagemInput").value = '';
            }
        });

        // Scroll to bottom on load
        document.addEventListener('DOMContentLoaded', () => {
            const msgs = document.getElementById("chatMessages");
            msgs.scrollTop = msgs.scrollHeight;
        });
    </script>
}

