@model IEnumerable<ProjetoEventX.Models.FotoGaleriaViewModel>
@{
    ViewBag.Title = "Mural de Fotos do Evento";
    var evento = ViewBag.Evento as ProjetoEventX.Models.Evento;
    var podeComentar = ViewBag.PodeComentar ?? false;
    var podeEnviar = ViewBag.PodeEnviar ?? false;
}

<div class="container py-4 animate-in">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-images text-primary me-2"></i> Mural de Fotos do Evento</h2>
            <div class="text-muted">Área social para compartilhar e reviver momentos do evento.</div>
        </div>
        @if (podeEnviar)
        {
            <a href="#" class="btn btn-primary btn-lg rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#modalEnviarFoto">
                <i class="fas fa-upload me-2"></i> Enviar Foto
            </a>
        }
    </div>
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="fas fa-images fa-2x mb-2"></i>
                <div>Nenhuma foto publicada ainda.</div>
            </div>
        }
        else
        {
            @foreach (var foto in Model.OrderByDescending(f => f.DataHora))
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card mural-card shadow-sm rounded-4 mb-3">
                        <div class="mural-img-box position-relative">
                            <img src="@foto.ImagemUrl" class="img-fluid rounded-top-4 mural-img" alt="Foto do evento" />
                            <button class="btn btn-sm btn-outline-light mural-detail-btn position-absolute top-0 end-0 m-2" data-bs-toggle="modal" data-bs-target="#modalDetalheFoto-@foto.Id"><i class="fas fa-search-plus"></i></button>
                        </div>
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center mb-1">
                                <img src="@foto.Autor.FotoPerfilUrl" class="rounded-circle me-2" style="width:28px;height:28px;object-fit:cover;" />
                                <strong>@foto.Autor.Nome</strong>
                                <span class="ms-2 text-muted small">@foto.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="mural-legenda text-muted small">@foto.Legenda</div>
                        </div>
                    </div>
                    <!-- Modal Detalhe Foto -->
                    <div class="modal fade" id="modalDetalheFoto-@foto.Id" tabindex="-1" aria-labelledby="modalDetalheFotoLabel-@foto.Id" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content rounded-4">
                                <div class="modal-body">
                                    <img src="@foto.ImagemUrl" class="img-fluid rounded mb-3" />
                                    <div class="d-flex align-items-center mb-2">
                                        <img src="@foto.Autor.FotoPerfilUrl" class="rounded-circle me-2" style="width:32px;height:32px;object-fit:cover;" />
                                        <strong>@foto.Autor.Nome</strong>
                                        <span class="ms-2 text-muted small">@foto.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                    <div class="mb-2 mural-legenda">@foto.Legenda</div>
                                    @if (podeComentar)
                                    {
                                        <div class="mural-comentarios mt-3">
                                            <h6 class="fw-bold mb-2">Comentários</h6>
                                            @if (foto.Comentarios != null && foto.Comentarios.Any())
                                            {
                                                @foreach (var comentario in foto.Comentarios.OrderBy(c => c.DataHora))
                                                {
                                                    <div class="comment mb-2 p-2 rounded bg-light">
                                                        <div class="d-flex align-items-center mb-1">
                                                            <img src="@comentario.Autor.FotoPerfilUrl" class="rounded-circle me-2" style="width:28px;height:28px;object-fit:cover;" />
                                                            <strong>@comentario.Autor.Nome</strong>
                                                            <span class="ms-2 text-muted small">@comentario.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
                                                        </div>
                                                        <div>@comentario.Texto</div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-muted small">Nenhum comentário ainda.</div>
                                            }
                                            <form asp-action="ComentarFoto" method="post" class="mt-2">
                                                <input type="hidden" name="fotoId" value="@foto.Id" />
                                                <textarea name="texto" class="form-control rounded-3 mb-2" rows="2" placeholder="Escreva um comentário..."></textarea>
                                                <button type="submit" class="btn btn-sm btn-primary rounded-pill">Comentar</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
    <!-- Modal Enviar Foto -->
    <div class="modal fade" id="modalEnviarFoto" tabindex="-1" aria-labelledby="modalEnviarFotoLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-body p-4">
                    <h5 class="fw-bold mb-3">Enviar Foto para o Mural</h5>
                    <form asp-action="EnviarFoto" method="post" enctype="multipart/form-data" autocomplete="off">
                        <input type="hidden" name="EventoId" value="@evento?.Id" />
                        <div class="mb-3">
                            <label for="Imagem" class="form-label">Imagem</label>
                            <input type="file" class="form-control rounded-pill" id="Imagem" name="Imagem" accept="image/*" required />
                        </div>
                        <div class="mb-3">
                            <label for="Legenda" class="form-label">Legenda <span class="text-muted">(opcional)</span></label>
                            <input type="text" class="form-control rounded-pill" id="Legenda" name="Legenda" placeholder="Legenda curta" />
                        </div>
                        <div class="d-flex gap-3 mt-4 justify-content-end">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">Enviar Foto</button>
                            <button type="button" class="btn btn-outline-secondary btn-lg rounded-pill px-5 fw-bold" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
.mural-card {
    border-radius: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.mural-img-box {
    height: 180px;
    overflow: hidden;
    border-radius: 1.5rem 1.5rem 0 0;
    background: #f5f1ed;
}
.mural-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.mural-detail-btn {
    opacity: 0.85;
}
.mural-legenda {
    font-size: 0.92rem;
    color: #888;
}
.comment {
    border-radius: 1rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
</style>
