@model IEnumerable<ProjetoEventX.Models.FotoGaleriaViewModel>
@{
    ViewBag.Title = "Moderação de Fotos do Mural";
    var evento = ViewBag.Evento as ProjetoEventX.Models.Evento;
}

<div class="container py-4 animate-in">
    <div class="mb-4">
        <h2 class="fw-bold mb-1"><i class="fas fa-shield-alt text-primary me-2"></i> Moderação de Fotos do Mural</h2>
        <div class="text-muted">Aprove, rejeite ou exclua fotos enviadas pelos convidados.</div>
    </div>
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="fas fa-shield-alt fa-2x mb-2"></i>
                <div>Nenhuma foto pendente de moderação.</div>
            </div>
        }
        else
        {
            @foreach (var foto in Model.OrderByDescending(f => f.DataHora))
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card mural-card shadow-sm rounded-4 mb-3">
                        <div class="mural-img-box position-relative">
                            <img src="@foto.ImagemUrl" class="img-fluid rounded-top-4 mural-img" alt="Foto do evento" />
                        </div>
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center mb-1">
                                <img src="@foto.Autor.FotoPerfilUrl" class="rounded-circle me-2" style="width:28px;height:28px;object-fit:cover;" />
                                <strong>@foto.Autor.Nome</strong>
                                <span class="ms-2 text-muted small">@foto.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="mural-legenda text-muted small">@foto.Legenda</div>
                            <div class="d-flex gap-2 mt-2">
                                <form asp-action="AprovarFoto" method="post" style="display:inline">
                                    <input type="hidden" name="fotoId" value="@foto.Id" />
                                    <button type="submit" class="btn btn-sm btn-success rounded-pill"><i class="fas fa-check"></i> Aprovar</button>
                                </form>
                                <form asp-action="RejeitarFoto" method="post" style="display:inline">
                                    <input type="hidden" name="fotoId" value="@foto.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning rounded-pill"><i class="fas fa-times"></i> Rejeitar</button>
                                </form>
                                <form asp-action="ExcluirFoto" method="post" style="display:inline">
                                    <input type="hidden" name="fotoId" value="@foto.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill"><i class="fas fa-trash-alt"></i> Excluir</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
<style>
.mural-card {
    border-radius: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.mural-img-box {
    height: 180px;
    overflow: hidden;
    border-radius: 1.5rem 1.5rem 0 0;
    background: #f5f1ed;
}
.mural-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.mural-legenda {
    font-size: 0.92rem;
    color: #888;
}
</style>
