@model ProjetoEventX.Models.FotoGaleriaViewModel
@{
    ViewBag.Title = "Enviar Foto para o Mural";
    var eventoId = ViewBag.EventoId;
    var pendenteAprovacao = ViewBag.PendenteAprovacao ?? false;
}

<div class="container py-4 animate-in" style="max-width:420px;">
    <div class="card shadow-lg rounded-4 border-0">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-2 text-primary"><i class="fas fa-upload me-2"></i> Enviar Foto para o Mural</h2>
            <div class="text-muted mb-3">Compartilhe momentos do evento. Sua foto será vinculada ao evento e pode passar por moderação.</div>
            @if (pendenteAprovacao)
            {
                <div class="alert alert-warning mb-3">Sua foto está pendente de aprovação do organizador.</div>
            }
            <form asp-action="EnviarFoto" method="post" enctype="multipart/form-data" autocomplete="off">
                <input type="hidden" name="EventoId" value="@eventoId" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                <div class="mb-3">
                    <label for="Imagem" class="form-label">Foto</label>
                    <input type="file" class="form-control rounded-pill" id="Imagem" name="Imagem" accept="image/*" required onchange="previewImagem(this)" />
                </div>
                <div class="mb-3">
                    <label for="Legenda" class="form-label">Legenda <span class="text-muted">(opcional)</span></label>
                    <input type="text" class="form-control rounded-pill" id="Legenda" name="Legenda" placeholder="Legenda curta" />
                </div>
                <div class="mb-3 d-none" id="previewArea">
                    <label class="form-label">Pré-visualização</label>
                    <img id="previewImg" class="img-fluid rounded mb-2" style="max-height:220px;" />
                </div>
                <div class="d-flex gap-3 mt-4 justify-content-end">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">Enviar Foto</button>
                    <a href="@Url.Action("Mural", new { eventoId = eventoId })" class="btn btn-outline-secondary btn-lg rounded-pill px-5 fw-bold">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
function previewImagem(input) {
    const previewArea = document.getElementById('previewArea');
    const previewImg = document.getElementById('previewImg');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            previewImg.src = e.target.result;
            previewArea.classList.remove('d-none');
        };
        reader.readAsDataURL(input.files[0]);
    } else {
        previewArea.classList.add('d-none');
    }
}
</script>
