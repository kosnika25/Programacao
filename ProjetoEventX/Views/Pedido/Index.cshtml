@model IEnumerable<ProjetoEventX.Models.Pedido>
@{
    ViewData["Title"] = "Pedidos";
}

@{
    var tipoUsuario = (string?)ViewBag.TipoUsuario ?? "";
    var isFornecedor = tipoUsuario == "Fornecedor";
    var isOrganizador = tipoUsuario == "Organizador";
}

@{ ViewData["HeroIcon"] = "fas fa-shopping-cart"; ViewData["HeroTitle"] = "Pedidos"; ViewData["HeroSubtitle"] = "Controle solicitações, aprovações e entregas em um fluxo único e padronizado."; ViewData["HeroClass"] = "mt-4"; }
@await Html.PartialAsync("_PageHero")

<div class="page-header-bar">
    <div>
        <p>
            @if (isFornecedor)
            {
                @:Gerencie os pedidos recebidos para seus produtos
            }
            else
            {
                @:Acompanhe os pedidos dos seus eventos
            }
            @if (ViewBag.EventoNome != null)
            {
                <span class="badge-eventx badge-info ms-2">@ViewBag.EventoNome</span>
            }
        </p>
    </div>
    <div>
        @if (isOrganizador && ViewBag.EventoId != null)
        {
            <a asp-action="Create" asp-route-eventoId="@ViewBag.EventoId" class="btn btn-eventx-primary">
                <i class="fas fa-plus me-1"></i> Novo Pedido
            </a>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Any())
{
    <!-- Resumo Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="stat-card-mini">
                <div class="stat-mini-icon purple"><i class="fas fa-shopping-cart"></i></div>
                <div>
                    <div class="stat-mini-value">@Model.Count()</div>
                    <div class="stat-mini-label">Total de Pedidos</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card-mini">
                <div class="stat-mini-icon amber"><i class="fas fa-clock"></i></div>
                <div>
                    <div class="stat-mini-value">@Model.Count(p => p.StatusPedido == "Pendente")</div>
                    <div class="stat-mini-label">Pendentes</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card-mini">
                <div class="stat-mini-icon green"><i class="fas fa-check-circle"></i></div>
                <div>
                    <div class="stat-mini-value">@Model.Count(p => p.StatusPedido == "Pago" || p.StatusPedido == "Entregue")</div>
                    <div class="stat-mini-label">Confirmados</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card-mini">
                <div class="stat-mini-icon blue"><i class="fas fa-dollar-sign"></i></div>
                <div>
                    <div class="stat-mini-value" style="color:var(--eventx-success);">R$ @Model.Sum(p => p.PrecoTotal).ToString("N2")</div>
                    <div class="stat-mini-label">Valor Total</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros rápidos -->
    <div class="filters-bar mb-3">
        <span class="fw-bold" style="font-size:0.85rem; color:var(--eventx-text-muted);"><i class="fas fa-filter me-1"></i>Status:</span>
        <button class="btn btn-sm btn-eventx-outline pedido-filter active" data-filter="todos">Todos</button>
        <button class="btn btn-sm btn-eventx-outline pedido-filter" data-filter="Pendente">Pendente</button>
        <button class="btn btn-sm btn-eventx-outline pedido-filter" data-filter="Pago">Pago</button>
        <button class="btn btn-sm btn-eventx-outline pedido-filter" data-filter="Entregue">Entregue</button>
        <button class="btn btn-sm btn-eventx-outline pedido-filter" data-filter="Cancelado">Cancelado</button>
    </div>

    <!-- Tabela de Pedidos -->
    <div class="saas-card-v2">
        <div class="table-responsive">
            <table class="table-eventx">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Evento</th>
                        <th>Qtd</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Data</th>
                        @if (isFornecedor)
                        {
                            <th>Organizador</th>
                        }
                        <th style="text-align:right;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in Model)
                    {
                        var badgeClass = pedido.StatusPedido switch
                        {
                            "Pendente" => "badge-pendente",
                            "Pago" => "badge-pago",
                            "Entregue" => "badge-entregue",
                            "Cancelado" => "badge-cancelado",
                            _ => "badge-info"
                        };
                        <tr data-status="@pedido.StatusPedido">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="fas fa-box" style="color:#7C3AED;font-size:0.85rem;"></i>
                                    </div>
                                    <strong>@pedido.Produto?.Nome</strong>
                                </div>
                            </td>
                            <td>@pedido.Evento?.NomeEvento</td>
                            <td><span class="badge-eventx badge-info">@pedido.Quantidade</span></td>
                            <td><strong style="color:var(--eventx-text);">R$ @pedido.PrecoTotal.ToString("N2")</strong></td>
                            <td><span class="badge-eventx @badgeClass">@pedido.StatusPedido</span></td>
                            <td style="color:var(--eventx-text-muted);">@pedido.DataPedido.ToString("dd/MM/yyyy")</td>
                            @if (isFornecedor)
                            {
                                <td>@(pedido.Evento?.NomeEvento ?? "—")</td>
                            }
                            <td style="text-align:right;">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-sm btn-eventx-outline" title="Detalhes">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (isFornecedor && pedido.StatusPedido == "Pendente")
                                    {
                                        <form asp-action="AtualizarStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@pedido.Id" />
                                            <input type="hidden" name="novoStatus" value="Pago" />
                                            <button type="submit" class="btn btn-sm" style="background:#ECFDF5;color:#059669;border:1px solid #A7F3D0;" title="Confirmar">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                        <form asp-action="Cancelar" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@pedido.Id" />
                                            <button type="submit" class="btn btn-sm" style="background:#FEF2F2;color:#DC2626;border:1px solid #FECACA;" title="Recusar"
                                                    onclick="return confirm('Recusar este pedido?')">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (isFornecedor && pedido.StatusPedido == "Pago")
                                    {
                                        <form asp-action="AtualizarStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@pedido.Id" />
                                            <input type="hidden" name="novoStatus" value="Entregue" />
                                            <button type="submit" class="btn btn-sm" style="background:#EFF6FF;color:#2563EB;border:1px solid #BFDBFE;" title="Marcar Entregue">
                                                <i class="fas fa-truck"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="eventx-empty-state">
        <div class="eventx-empty-state-icon">
            <i class="fas fa-shopping-cart"></i>
        </div>
        <h4>Nenhum pedido encontrado</h4>
        <p>Comece criando um pedido para o seu evento.</p>
        @if (ViewBag.EventoId != null)
        {
            <a asp-action="Create" asp-route-eventoId="@ViewBag.EventoId" class="btn btn-eventx-primary mt-2">
                <i class="fas fa-plus me-1"></i> Criar Primeiro Pedido
            </a>
        }
        else
        {
            <a asp-controller="Eventos" asp-action="Index" class="btn btn-eventx-primary mt-2">
                <i class="fas fa-calendar-alt me-1"></i> Ver Meus Eventos
            </a>
        }
    </div>
}

<div class="mt-3">
    @if (isFornecedor)
    {
        <a asp-controller="Fornecedor" asp-action="Dashboard" class="btn btn-eventx-outline">
            <i class="fas fa-arrow-left me-1"></i> Voltar ao Dashboard
        </a>
    }
    else if (ViewBag.EventoId != null)
    {
        <a asp-controller="Organizador" asp-action="DetalhesEvento" asp-route-id="@ViewBag.EventoId" class="btn btn-eventx-outline">
            <i class="fas fa-arrow-left me-1"></i> Voltar ao Evento
        </a>
    }
    else
    {
        <a asp-controller="Organizador" asp-action="Dashboard" class="btn btn-eventx-outline">
            <i class="fas fa-arrow-left me-1"></i> Voltar ao Dashboard
        </a>
    }
</div>

@section Scripts {
<script>
document.querySelectorAll('.pedido-filter').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.pedido-filter').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const f = this.dataset.filter;
        document.querySelectorAll('tbody tr[data-status]').forEach(r => {
            r.style.display = (f === 'todos' || r.dataset.status === f) ? '' : 'none';
        });
    });
});
</script>
}
